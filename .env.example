# Copy to .env.local for local API testing (never commit real keys)
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO=info@nestfigure.com
# From is hard-coded in api/contact.js as Nestfigure <info@nestfigure.com>

# Star ratings (Upstash Redis free tier, or Vercel KV)
# Without these, ratings use in-memory storage (resets on cold start — fine for local only)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxx
