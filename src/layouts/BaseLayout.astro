---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogImage = '/images/og-default.webp',
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL('https://nestfigure.com');
const canonical = new URL(canonicalPath, site).toString();
const ogImageUrl = new URL(ogImage, site).toString();
const jsonLdItems = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="dh8GEJtu_kK4o3hw2RlBDIbnNo1MHc17lX8iFet6Q-Y" />
    <link rel="canonical" href={canonical} />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RLC6KSL57V" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-RLC6KSL57V');
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nestfigure" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    {
      jsonLdItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
  </head>
  <body>
    <header class="site-header">
      <div class="container inner">
        <a class="logo" href="/" aria-label="Nestfigure home">
          <img class="logo-mark" src="/logo-icon.svg" width="28" height="28" alt="" />
          <span class="logo-text">Nest<span>figure</span></span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a class="hide-sm" href="/">Home</a>
          <a href="/cd-calculator/">CD Calculator</a>
          <a class="hide-sm" href="/guides/">Guides</a>
          <a class="hide-sm" href="/about/">About</a>
          <a class="btn btn-primary" href="/cd-calculator/">Open tool</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container inner">
        <div>
          <a class="logo" href="/" aria-label="Nestfigure home">
            <img class="logo-mark" src="/logo-icon.svg" width="28" height="28" alt="" />
            <span class="logo-text">Nest<span>figure</span></span>
          </a>
          <p style="margin-top: 12px;">
            Free personal finance calculators for take-home pay, CDs, and debt.
            Results are estimates for education only — not financial advice.
          </p>
        </div>
        <div class="footer-links">
          <a href="/cd-calculator/">CD Calculator</a>
          <a href="/guides/">Guides</a>
          <a href="/guides/how-cd-interest-works/">How CD interest works</a>
          <a href="/guides/cd-vs-savings/">CD vs savings</a>
          <a href="/about/">About & methodology</a>
          <a href="/privacy/">Privacy</a>
        </div>
      </div>
    </footer>
  </body>
</html>
