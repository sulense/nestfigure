---
interface Props {
  /** CSS selector for the content root to read */
  targetSelector?: string;
}
const { targetSelector = '[data-tts-content]' } = Astro.props;
---

<div class="tts" data-tts data-target={targetSelector} data-state="idle" data-expanded="false">
  <!-- Morphing shell: pill button → full player -->
  <div class="tts-surface">
    <button type="button" class="tts-launch" data-tts-launch aria-expanded="false" aria-controls="tts-panel">
      <span class="tts-launch-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
          <path d="M8 5.14v13.72L19.5 12 8 5.14z"></path>
        </svg>
      </span>
      <span class="tts-launch-text">Play Audio</span>
    </button>

    <div class="tts-panel-shell">
      <div class="tts-panel-shell-inner">
        <div
          class="tts-panel"
          id="tts-panel"
          data-tts-panel
          role="region"
          aria-label="Audio player"
          aria-hidden="true"
          inert
        >
          <div class="tts-panel-head">
            <div class="tts-panel-title">
              <span class="tts-eq" aria-hidden="true" data-tts-eq>
                <i></i><i></i><i></i><i></i>
              </span>
              <span data-tts-heading>Audio</span>
            </div>
            <button type="button" class="tts-collapse" data-tts-collapse aria-label="Collapse audio player">
              Close
            </button>
          </div>

          <div class="tts-progress-wrap">
            <div
              class="tts-progress"
              role="progressbar"
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow="0"
              aria-label="Audio progress"
              data-tts-progress
            >
              <div class="tts-progress-fill" data-tts-progress-fill></div>
            </div>
            <div class="tts-progress-meta">
              <span data-tts-progress-label>0%</span>
              <span data-tts-chunk-label></span>
            </div>
          </div>

          <div class="tts-controls" role="group" aria-label="Audio controls">
            <button type="button" class="tts-btn tts-btn-primary" data-tts-play>Play</button>
            <button type="button" class="tts-btn" data-tts-pause hidden>Pause</button>
            <button type="button" class="tts-btn" data-tts-resume hidden>Resume</button>
            <button type="button" class="tts-btn" data-tts-stop hidden>Stop</button>
            <label class="tts-rate">
              <span class="visually-hidden">Speed</span>
              <select data-tts-rate aria-label="Speech speed">
                <option value="0.85">Slow</option>
                <option value="1" selected>Normal</option>
                <option value="1.15">Fast</option>
              </select>
            </label>
          </div>

          <p class="tts-status" data-tts-status role="status" hidden></p>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* Center the whole control in the guide container */
  .tts {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    margin: 0 0 24px;
    text-align: center;
  }

  /* Shared surface that morphs from pill → card */
  .tts-surface {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    box-sizing: border-box;
    width: 100%;
    max-width: 11.5rem; /* hugs the Play Audio pill when collapsed */
    margin-inline: auto;
    border: 1px solid var(--color-pale-slate, #d7dde3);
    border-radius: 9999px;
    background: #fff;
    box-shadow: 0 1px 2px rgba(39, 44, 48, 0.05);
    overflow: hidden;
    transition:
      max-width 0.65s cubic-bezier(0.22, 1, 0.36, 1),
      border-radius 0.65s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.5s ease,
      box-shadow 0.5s ease,
      padding 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .tts[data-expanded='true'] .tts-surface {
    max-width: 42rem;
    border-radius: 12px;
    background: #fafbfc;
    box-shadow: 0 4px 20px rgba(39, 44, 48, 0.07);
    padding: 0;
  }

  /* —— Launch button (centered inside the pill) —— */
  .tts-launch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    min-height: 42px;
    margin: 0;
    padding: 8px 16px 8px 12px;
    border: none;
    border-radius: 9999px;
    background: transparent;
    color: var(--color-ink, #272c30);
    font-family: var(--font-ui, system-ui, sans-serif);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    opacity: 1;
    transform: scale(1);
    transition:
      opacity 0.4s ease,
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      max-height 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      padding 0.45s ease,
      min-height 0.45s ease;
  }

  .tts-launch:hover {
    background: #f8faff;
  }

  .tts-launch:focus-visible {
    outline: 3px solid rgba(37, 99, 235, 0.25);
    outline-offset: 2px;
  }

  .tts[data-expanded='true'] .tts-launch {
    opacity: 0;
    transform: scale(0.92);
    max-height: 0;
    min-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .tts-launch-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 9999px;
    background: #2563eb;
    color: #fff;
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .tts-launch:hover .tts-launch-icon {
    transform: scale(1.08);
  }

  /* —— Player panel (height expand) —— */
  .tts-panel-shell {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.45s ease 0.08s;
  }

  .tts[data-expanded='true'] .tts-panel-shell {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .tts-panel-shell-inner {
    overflow: hidden;
    min-height: 0;
  }

  .tts-panel {
    padding: 0 14px;
    text-align: left;
    transform: translateY(10px);
    transition:
      transform 0.65s cubic-bezier(0.22, 1, 0.36, 1),
      padding 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .tts[data-expanded='true'] .tts-panel {
    padding: 14px 16px 16px;
    transform: translateY(0);
  }

  .tts-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .tts-panel-title {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-ink, #272c30);
  }

  .tts-eq {
    display: inline-flex;
    align-items: flex-end;
    gap: 2px;
    height: 12px;
    width: 14px;
  }

  .tts-eq i {
    display: block;
    width: 2px;
    height: 4px;
    border-radius: 1px;
    background: var(--color-dove-gray, #9aa3ad);
  }

  .tts[data-state='playing'] .tts-eq i {
    background: #2563eb;
    animation: tts-eq 0.85s ease-in-out infinite;
  }

  .tts[data-state='playing'] .tts-eq i:nth-child(1) {
    animation-delay: 0s;
  }
  .tts[data-state='playing'] .tts-eq i:nth-child(2) {
    height: 8px;
    animation-delay: 0.1s;
  }
  .tts[data-state='playing'] .tts-eq i:nth-child(3) {
    height: 11px;
    animation-delay: 0.2s;
  }
  .tts[data-state='playing'] .tts-eq i:nth-child(4) {
    height: 6px;
    animation-delay: 0.15s;
  }

  @keyframes tts-eq {
    0%,
    100% {
      transform: scaleY(0.45);
    }
    50% {
      transform: scaleY(1);
    }
  }

  .tts-collapse {
    appearance: none;
    border: none;
    background: transparent;
    color: var(--color-graphite, #5c6670);
    font-family: var(--font-ui, system-ui, sans-serif);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    padding: 4px 6px;
    border-radius: 4px;
  }

  .tts-collapse:hover {
    color: var(--color-ink, #272c30);
    background: #fff;
  }

  .tts-progress-wrap {
    margin-bottom: 12px;
  }

  .tts-progress {
    height: 6px;
    border-radius: 9999px;
    background: #e8eef3;
    overflow: hidden;
  }

  .tts-progress-fill {
    height: 100%;
    width: 0%;
    border-radius: 9999px;
    background: linear-gradient(90deg, #3b82f6, #2563eb);
    transition: width 0.25s ease;
  }

  .tts[data-state='playing'] .tts-progress-fill {
    transition: width 0.35s linear;
  }

  .tts-progress-meta {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-top: 6px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-graphite, #5c6670);
  }

  .tts-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }

  .tts-btn {
    appearance: none;
    border: 1px solid var(--color-pale-slate, #d7dde3);
    background: #fff;
    color: var(--color-iron, #3d454d);
    font-family: var(--font-ui, system-ui, sans-serif);
    font-size: 12px;
    font-weight: 600;
    padding: 6px 11px;
    border-radius: 6px;
    cursor: pointer;
    line-height: 1.2;
  }

  .tts-btn:hover {
    border-color: var(--color-dove-gray, #9aa3ad);
    color: var(--color-ink, #272c30);
  }

  .tts-btn-primary {
    border-color: #bfdbfe;
    color: #1d4ed8;
    background: #eff6ff;
  }

  .tts-rate select {
    font-family: var(--font-ui, system-ui, sans-serif);
    font-size: 12px;
    color: var(--color-iron, #3d454d);
    border: 1px solid var(--color-pale-slate, #d7dde3);
    border-radius: 6px;
    padding: 6px 8px;
    background: #fff;
  }

  .tts-status {
    margin: 10px 0 0;
    font-size: 12px;
    color: var(--color-graphite, #5c6670);
  }

  .tts-status.err {
    color: #7f1d1d;
  }

  .tts .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .tts.is-unsupported .tts-launch-icon {
    background: #94a3b8;
  }

  @media (prefers-reduced-motion: reduce) {
    .tts-surface,
    .tts-launch,
    .tts-panel-shell,
    .tts-panel,
    .tts-launch-icon {
      transition: none !important;
    }

    .tts[data-expanded='true'] .tts-panel {
      transform: none;
    }
  }
</style>

<script>
  type SpeechState = 'idle' | 'playing' | 'paused';

  function chunkText(text: string, maxLen = 180): string[] {
    const cleaned = text.replace(/\s+/g, ' ').trim();
    if (!cleaned) return [];
    const parts: string[] = [];
    const sentences = cleaned.match(/[^.!?]+[.!?]+|[^.!?]+$/g) || [cleaned];
    let buf = '';
    for (const s of sentences) {
      const piece = s.trim();
      if (!piece) continue;
      if ((buf + ' ' + piece).trim().length <= maxLen) {
        buf = (buf + ' ' + piece).trim();
      } else {
        if (buf) parts.push(buf);
        if (piece.length <= maxLen) {
          buf = piece;
        } else {
          for (let i = 0; i < piece.length; i += maxLen) {
            parts.push(piece.slice(i, i + maxLen));
          }
          buf = '';
        }
      }
    }
    if (buf) parts.push(buf);
    return parts;
  }

  function extractText(root: Element): string {
    const clone = root.cloneNode(true) as HTMLElement;
    clone
      .querySelectorAll(
        'script, style, noscript, .tts, [data-tts], [data-tts-skip], .guide-cta, .hp, .author-byline, [data-cd-calculator], .calc',
      )
      .forEach((el) => el.remove());
    const bits: string[] = [];
    clone.querySelectorAll('h1, h2, h3, p, li, figcaption, summary, td, th').forEach((el) => {
      const t = (el.textContent || '').replace(/\s+/g, ' ').trim();
      if (t) bits.push(t);
    });
    if (bits.length) return bits.join('. ').replace(/\.\s*\./g, '.');
    return (clone.textContent || '').replace(/\s+/g, ' ').trim();
  }

  function bind(widget: HTMLElement) {
    const launchBtn = widget.querySelector<HTMLButtonElement>('[data-tts-launch]');
    const panel = widget.querySelector<HTMLElement>('[data-tts-panel]');
    const collapseBtn = widget.querySelector<HTMLButtonElement>('[data-tts-collapse]');
    const playBtn = widget.querySelector<HTMLButtonElement>('[data-tts-play]');
    const pauseBtn = widget.querySelector<HTMLButtonElement>('[data-tts-pause]');
    const resumeBtn = widget.querySelector<HTMLButtonElement>('[data-tts-resume]');
    const stopBtn = widget.querySelector<HTMLButtonElement>('[data-tts-stop]');
    const rateSel = widget.querySelector<HTMLSelectElement>('[data-tts-rate]');
    const statusEl = widget.querySelector<HTMLElement>('[data-tts-status]');
    const progressEl = widget.querySelector<HTMLElement>('[data-tts-progress]');
    const progressFill = widget.querySelector<HTMLElement>('[data-tts-progress-fill]');
    const progressLabel = widget.querySelector<HTMLElement>('[data-tts-progress-label]');
    const chunkLabel = widget.querySelector<HTMLElement>('[data-tts-chunk-label]');
    const heading = widget.querySelector<HTMLElement>('[data-tts-heading]');
    const selector = widget.dataset.target || '[data-tts-content]';

    if (!('speechSynthesis' in window) || typeof SpeechSynthesisUtterance === 'undefined') {
      widget.classList.add('is-unsupported');
      if (launchBtn) {
        launchBtn.disabled = true;
        launchBtn.querySelector('.tts-launch-text')!.textContent = 'Audio unavailable';
      }
      return;
    }

    let state: SpeechState = 'idle';
    let queue: string[] = [];
    let index = 0;
    let chunkBoundary = 0;
    let boundaryTimer: number | null = null;
    let expandTimer: number | null = null;

    function setExpanded(open: boolean) {
      widget.dataset.expanded = open ? 'true' : 'false';
      if (panel) {
        panel.setAttribute('aria-hidden', open ? 'false' : 'true');
        if (open) panel.removeAttribute('inert');
        else panel.setAttribute('inert', '');
      }
      if (launchBtn) {
        launchBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
        launchBtn.tabIndex = open ? -1 : 0;
      }
    }

    function setStatus(msg: string, err = false) {
      if (!statusEl) return;
      if (!msg) {
        statusEl.hidden = true;
        statusEl.textContent = '';
        statusEl.className = 'tts-status';
        return;
      }
      statusEl.hidden = false;
      statusEl.textContent = msg;
      statusEl.className = err ? 'tts-status err' : 'tts-status';
    }

    function updateProgress() {
      const total = queue.length || 1;
      const raw = state === 'idle' && index === 0 ? 0 : (index + (state === 'idle' ? 0 : chunkBoundary)) / total;
      const pct = Math.max(0, Math.min(100, Math.round(raw * 100)));
      if (progressFill) progressFill.style.width = `${pct}%`;
      if (progressEl) progressEl.setAttribute('aria-valuenow', String(pct));
      if (progressLabel) progressLabel.textContent = `${pct}%`;
      if (chunkLabel) {
        if (!queue.length || state === 'idle') chunkLabel.textContent = '';
        else chunkLabel.textContent = `Part ${Math.min(index + 1, total)} of ${total}`;
      }
    }

    function syncUi() {
      widget.dataset.state = state;
      if (playBtn) playBtn.hidden = state !== 'idle';
      if (pauseBtn) pauseBtn.hidden = state !== 'playing';
      if (resumeBtn) resumeBtn.hidden = state !== 'paused';
      if (stopBtn) stopBtn.hidden = state === 'idle';
      if (heading) {
        if (state === 'playing') heading.textContent = 'Playing audio';
        else if (state === 'paused') heading.textContent = 'Audio paused';
        else heading.textContent = 'Audio';
      }
      updateProgress();
    }

    function pickVoice(): SpeechSynthesisVoice | null {
      const voices = window.speechSynthesis.getVoices();
      if (!voices.length) return null;
      const en = voices.filter((v) => /^en(-|_)/i.test(v.lang) || /english/i.test(v.name));
      const pool = en.length ? en : voices;
      return (
        pool.find((v) => /natural|neural|premium|enhanced/i.test(v.name)) ||
        pool.find((v) => v.localService) ||
        pool[0] ||
        null
      );
    }

    function clearBoundaryTimer() {
      if (boundaryTimer != null) {
        window.clearInterval(boundaryTimer);
        boundaryTimer = null;
      }
    }

    function speakNext() {
      clearBoundaryTimer();
      chunkBoundary = 0;
      if (index >= queue.length) {
        state = 'idle';
        chunkBoundary = 0;
        index = queue.length;
        setStatus('Finished.');
        if (progressFill) progressFill.style.width = '100%';
        if (progressLabel) progressLabel.textContent = '100%';
        if (progressEl) progressEl.setAttribute('aria-valuenow', '100');
        if (chunkLabel) chunkLabel.textContent = '';
        window.setTimeout(() => {
          if (state === 'idle') {
            index = 0;
            updateProgress();
          }
        }, 800);
        syncUi();
        return;
      }

      const text = queue[index];
      const utter = new SpeechSynthesisUtterance(text);
      const voice = pickVoice();
      if (voice) utter.voice = voice;
      utter.rate = Number(rateSel?.value || 1);
      utter.pitch = 1;
      utter.lang = voice?.lang || 'en-US';

      const words = text.split(/\s+/).filter(Boolean).length || 1;
      let wordIdx = 0;
      utter.onboundary = (ev) => {
        if (ev.name === 'word' || ev.charIndex != null) {
          wordIdx += 1;
          chunkBoundary = Math.min(0.95, wordIdx / words);
          updateProgress();
        }
      };
      const estMs = Math.max(1200, (text.length / 14) * 1000) / Number(rateSel?.value || 1);
      const started = Date.now();
      boundaryTimer = window.setInterval(() => {
        if (state !== 'playing') return;
        const t = Math.min(0.9, (Date.now() - started) / estMs);
        if (t > chunkBoundary) {
          chunkBoundary = t;
          updateProgress();
        }
      }, 200);

      utter.onend = () => {
        clearBoundaryTimer();
        chunkBoundary = 0;
        index += 1;
        updateProgress();
        if (state === 'playing') speakNext();
      };
      utter.onerror = () => {
        clearBoundaryTimer();
        chunkBoundary = 0;
        index += 1;
        if (state === 'playing') speakNext();
      };

      state = 'playing';
      syncUi();
      window.speechSynthesis.speak(utter);
    }

    function prepareQueue(): boolean {
      const root = document.querySelector(selector);
      if (!root) {
        setStatus('Could not find article text.', true);
        return false;
      }
      queue = chunkText(extractText(root));
      if (!queue.length) {
        setStatus('No readable text found.', true);
        return false;
      }
      return true;
    }

    function start() {
      window.speechSynthesis.cancel();
      clearBoundaryTimer();
      if (!prepareQueue()) return;
      index = 0;
      chunkBoundary = 0;
      state = 'playing';
      setStatus('Playing…');
      syncUi();
      window.setTimeout(() => speakNext(), 50);
    }

    function pause() {
      if (state !== 'playing') return;
      window.speechSynthesis.pause();
      clearBoundaryTimer();
      state = 'paused';
      setStatus('Paused.');
      syncUi();
    }

    function resume() {
      if (state !== 'paused') return;
      window.speechSynthesis.resume();
      state = 'playing';
      setStatus('Playing…');
      syncUi();
    }

    function stop() {
      window.speechSynthesis.cancel();
      clearBoundaryTimer();
      state = 'idle';
      queue = [];
      index = 0;
      chunkBoundary = 0;
      setStatus('');
      syncUi();
    }

    function openAndPlay() {
      if (expandTimer != null) {
        window.clearTimeout(expandTimer);
        expandTimer = null;
      }
      setExpanded(true);
      // Let the morph animation begin before speech starts
      expandTimer = window.setTimeout(() => {
        expandTimer = null;
        start();
      }, 280);
    }

    function collapse() {
      if (expandTimer != null) {
        window.clearTimeout(expandTimer);
        expandTimer = null;
      }
      stop();
      setExpanded(false);
    }

    launchBtn?.addEventListener('click', openAndPlay);
    collapseBtn?.addEventListener('click', collapse);
    playBtn?.addEventListener('click', start);
    pauseBtn?.addEventListener('click', pause);
    resumeBtn?.addEventListener('click', resume);
    stopBtn?.addEventListener('click', stop);

    window.speechSynthesis.onvoiceschanged = () => {};
    window.addEventListener('pagehide', stop);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden && state === 'playing') pause();
    });

    setExpanded(false);
    syncUi();
  }

  document.querySelectorAll<HTMLElement>('[data-tts]').forEach(bind);
</script>
