    </div>
    <p class="footer">Generated by Nestfigure · https://nestfigure.com/cd-calculator/</p>
  </div>
</body>
</html>`;
  }

  function exportPdf() {
    try {
      const html = buildReportHtml();
      // Hidden iframe print avoids popup blockers and uses the browser's Save as PDF
      const iframe = document.createElement('iframe');
      iframe.setAttribute('title', 'PDF export');
      iframe.style.cssText =
        'position:fixed;right:0;bottom:0;width:0;height:0;border:0;opacity:0;pointer-events:none;';
      document.body.appendChild(iframe);

      const frameDoc = iframe.contentDocument || iframe.contentWindow?.document;
      if (!frameDoc || !iframe.contentWindow) {
        iframe.remove();
        throw new Error('iframe unavailable');
      }

      frameDoc.open();
      frameDoc.write(html);
      frameDoc.close();

      const runPrint = () => {
        try {
          iframe.contentWindow?.focus();
          iframe.contentWindow?.print();
          setActionStatus('Use “Save as PDF” in the print dialog.', 5000);
        } catch {
          setActionStatus('Could not open print dialog. Try Copy results instead.', 4000);
        }
        window.setTimeout(() => iframe.remove(), 2000);
      };

      // Wait a tick for layout/SVG paint before printing
      window.setTimeout(runPrint, 250);
    } catch {
      setActionStatus('Could not create PDF. Try Copy results instead.', 4000);
    }
  }

  /** Prefill from ?principal=&rate=&apy=&term=&termUnit=&months=&years=&compounding=&monthlyDeposit= */
  function applyQueryParams() {
    const params = new URLSearchParams(window.location.search);
    if (![...params.keys()].length) return;

    const num = (key: string): number | null => {
      const raw = params.get(key);
      if (raw == null || raw === '') return null;
      const v = parseFloat(raw);
      return Number.isFinite(v) && v >= 0 ? v : null;
    };

    const setInput = (id: string, value: number | string) => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = String(value);
    };

    const principal = num('principal') ?? num('deposit');
    if (principal != null) setInput('principal', principal);

    // apy= sets rate and forces APY mode; rate= uses rateType if present
    const apy = num('apy');
    const rate = num('rate');
    if (apy != null) {
      setInput('rate', apy);
      setInput('rateType', 'apy');
    } else if (rate != null) {
      setInput('rate', rate);
    }

    const rateType = params.get('rateType');
    if (rateType === 'apy' || rateType === 'apr') setInput('rateType', rateType);

    const months = num('months');
    const years = num('years');
    if (months != null) {
      setInput('term', Math.max(1, Math.round(months)));
      setInput('termUnit', 'months');
    } else if (years != null) {
      setInput('term', Math.max(1, years));
      setInput('termUnit', 'years');
    } else {
      const term = num('term');
      if (term != null) setInput('term', Math.max(1, term));
      const unit = params.get('termUnit');
      if (unit === 'months' || unit === 'years') setInput('termUnit', unit);
    }

    const compounding = params.get('compounding');
    const allowed = ['daily', 'monthly', 'quarterly', 'semiannually', 'annually', 'continuous'];
    if (compounding && allowed.includes(compounding)) setInput('compounding', compounding);

    const monthly =
      num('monthlyDeposit') ?? num('monthly') ?? num('addOn');
    if (monthly != null) setInput('monthlyDeposit', monthly);
  }

  function bind() {
    const form = document.getElementById('cd-form');
    if (!form) return;
    applyQueryParams();
    form.addEventListener('input', calculate);
    form.addEventListener('change', calculate);
    document.querySelectorAll('.preset').forEach((btn) => {
      btn.addEventListener('click', () => {
        const months = (btn as HTMLElement).dataset.months || '12';
        (document.getElementById('term') as HTMLInputElement).value = months;
        (document.getElementById('termUnit') as HTMLSelectElement).value = 'months';
        calculate();
      });
    });
    document.getElementById('copy-results')?.addEventListener('click', copyResults);
    document.getElementById('export-pdf')?.addEventListener('click', exportPdf);
    calculate();
  }

  bind();
</script>
