  }
  .footer {
    margin-top: 12px;
    font-size: 10px;
    color: #5c6670;
  }
  @media print {
    .banner { break-inside: avoid; }
    .metrics { break-inside: avoid; }
    .chart { break-inside: avoid; }
    table { break-inside: auto; }
    tr { break-inside: avoid; break-after: auto; }
    thead { display: table-header-group; }
  }
</style>
</head>
<body>
  <div class="sheet">
    <div class="banner">
      <div>
        <strong>Nestfigure</strong><br/>
        <span>CD Calculator Report</span>
      </div>
      <span>${esc(dateStr)}</span>
    </div>

    <h1>Your CD estimate</h1>
    <p class="meta">${esc(inputs.join('  ·  '))}</p>

    <div class="metrics">
      <div class="metric hero">
        <div class="lbl">Final balance</div>
        <div class="val">${esc(formatMoney(s.balance))}</div>
      </div>
      <div class="metric">
        <div class="lbl">Interest earned</div>
        <div class="val">${esc(formatMoney(s.interest))}</div>
      </div>
      <div class="metric">
        <div class="lbl">Total deposited</div>
        <div class="val">${esc(formatMoney(s.deposits))}</div>
      </div>
      <div class="metric">
        <div class="lbl">Effective APY</div>
        <div class="val">${esc(formatPercent(s.apy))}</div>
      </div>
      <div class="metric">
        <div class="lbl">Term</div>
        <div class="val">${esc(termLabel(s.termMonths))}</div>
      </div>
    </div>

    <h2>Balance over time</h2>
    <p class="sub">Projected balance from start to maturity</p>
    <div class="chart">
      ${chartSvgMarkup(s.points)}
      <div class="chart-axis"><span>Start</span><span>Maturity</span></div>
    </div>

    <h2>Compare common CD terms</h2>
