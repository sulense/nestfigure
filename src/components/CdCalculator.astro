  .chart-axis {
    display: flex;
    justify-content: space-between;
    color: #5c6670;
    font-size: 10px;
    padding: 0 6px 6px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    margin-bottom: 8px;
  }
  thead th {
    background: #2563eb;
    color: #fff;
    font-weight: 600;
    text-align: left;
