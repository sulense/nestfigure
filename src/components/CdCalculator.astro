    font-size: 12px;
    line-height: 1.45;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  .sheet { max-width: 800px; margin: 0 auto; }
  .banner {
    background: #2563eb;
    color: #fff;
    border-radius: 8px;
    padding: 14px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
  }
  .banner strong { font-size: 16px; letter-spacing: -0.01em; }
  .banner span { font-size: 11px; opacity: 0.92; }
  h1 { font-size: 20px; margin: 0 0 6px; font-weight: 650; letter-spacing: -0.02em; }
  .meta { color: #5c6670; font-size: 12px; margin: 0 0 16px; }
  .metrics {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr;
    gap: 8px;
    margin-bottom: 20px;
  }
  .metric {
    border: 1px solid #e3e8ea;
    border-radius: 8px;
    padding: 10px 12px;
    background: #fff;
  }
  .metric.hero {
    background: #f0f5fe;
    border-color: #d7e4fb;
  }
  .metric .lbl {
    font-size: 10px;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #5c6670;
    margin-bottom: 4px;
  }
  .metric .val {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 14px;
    font-weight: 600;
    color: #1a1f24;
  }
  .metric.hero .val {
    font-size: 22px;
    color: #2563eb;
    font-weight: 700;
  }
  h2 {
    font-size: 14px;
    margin: 22px 0 4px;
    font-weight: 650;
  }
  .sub { color: #5c6670; font-size: 11px; margin: 0 0 10px; }
  .chart {
    border: 1px solid #e3e8ea;
    border-radius: 8px;
    padding: 8px 10px 4px;
    background: #fff;
