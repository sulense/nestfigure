---
import { COMPOUNDING_OPTIONS } from '../lib/cdMath';
---

<div class="calc card-elevated" id="cd-calculator" data-cd-calculator>
  <div class="calc-grid">
    <form class="calc-form" id="cd-form" novalidate>
      <div class="calc-form-head">
        <span class="pill">Live</span>
        <span class="muted" style="font-size: 12px;">Updates as you type</span>
      </div>

      <div class="field">
        <label for="principal">Initial deposit</label>
        <input
          id="principal"
          name="principal"
          type="number"
          inputmode="decimal"
          min="0"
          step="100"
          value="10000"
          required
        />
      </div>

      <div class="field-row">
        <div class="field">
          <label for="rate">Rate (%)</label>
          <input
            id="rate"
            name="rate"
            type="number"
            inputmode="decimal"
            min="0"
            max="100"
            step="0.01"
            value="4.50"
            required
          />
        </div>
        <div class="field">
          <label for="rateType">Rate type</label>
          <select id="rateType" name="rateType">
            <option value="apy" selected>APY</option>
            <option value="apr">Nominal APR</option>
          </select>
        </div>
      </div>

      <div class="field-row">
        <div class="field">
          <label for="term">Term</label>
          <input
            id="term"
            name="term"
            type="number"
            inputmode="numeric"
            min="1"
            max="600"
            step="1"
            value="12"
            required
          />
        </div>
        <div class="field">
          <label for="termUnit">Unit</label>
          <select id="termUnit" name="termUnit">
            <option value="months" selected>Months</option>
            <option value="years">Years</option>
          </select>
        </div>
      </div>

      <div class="field">
        <label for="compounding">Compounding</label>
        <select id="compounding" name="compounding">
          {
            COMPOUNDING_OPTIONS.map((o) => (
              <option value={o.value} selected={o.value === 'daily'}>
                {o.label}
              </option>
            ))
          }
        </select>
        <span class="field-hint">Most bank CDs compound daily or monthly.</span>
      </div>

      <div class="field">
        <label for="monthlyDeposit">Monthly add-on deposit (optional)</label>
        <input
          id="monthlyDeposit"
          name="monthlyDeposit"
          type="number"
          inputmode="decimal"
          min="0"
          step="50"
          value="0"
        />
        <span class="field-hint">Models a CD-like savings plan; many true CDs don’t allow add-ons.</span>
      </div>

      <div class="preset-row" role="group" aria-label="Term presets">
        <button type="button" class="btn btn-secondary preset" data-months="3">3 mo</button>
        <button type="button" class="btn btn-secondary preset" data-months="6">6 mo</button>
        <button type="button" class="btn btn-secondary preset" data-months="12">12 mo</button>
        <button type="button" class="btn btn-secondary preset" data-months="24">24 mo</button>
        <button type="button" class="btn btn-secondary preset" data-months="60">5 yr</button>
      </div>
    </form>

    <div class="calc-results" aria-live="polite">
      <div class="result-block">
        <div class="result-label">Final balance</div>
        <div class="result-value" id="out-balance">$0.00</div>
      </div>
      <div class="result-grid">
        <div class="result-mini">
          <div class="result-label">Interest earned</div>
          <div class="result-mid" id="out-interest">$0.00</div>
        </div>
        <div class="result-mini">
          <div class="result-label">Total deposited</div>
          <div class="result-mid" id="out-deposits">$0.00</div>
        </div>
        <div class="result-mini">
          <div class="result-label">Effective APY</div>
          <div class="result-mid" id="out-apy">0.00%</div>
        </div>
        <div class="result-mini">
          <div class="result-label">Term</div>
          <div class="result-mid" id="out-term">—</div>
        </div>
      </div>
      <div class="result-actions">
        <button type="button" class="btn btn-secondary" id="copy-results">Copy results</button>
        <button type="button" class="btn btn-secondary" id="export-pdf">Export PDF</button>
      </div>
      <p class="result-note" id="copy-status" hidden></p>
      <p class="result-note">
        Illustrative estimate only. Actual bank CD rates, compounding, and early withdrawal penalties vary.
      </p>
    </div>
  </div>

  <div class="chart-block">
    <div class="schedule-head">
      <p class="heading-sm" style="margin:0">Balance over time</p>
      <span class="muted" style="font-size:12px">Growth chart</span>
    </div>
    <div class="chart-wrap" role="img" aria-label="CD balance growth chart">
      <div class="chart-y-axis" aria-hidden="true">
        <span id="chart-y-max">—</span>
        <span id="chart-y-mid">—</span>
        <span id="chart-y-min">—</span>
      </div>
      <div class="chart-main">
        <svg
          id="growth-chart"
          viewBox="0 0 800 280"
          preserveAspectRatio="xMidYMid meet"
          shape-rendering="geometricPrecision"
        >
          <defs>
            <linearGradient id="areaFill" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#3e79ea" stop-opacity="0.22" />
              <stop offset="100%" stop-color="#3e79ea" stop-opacity="0.02" />
            </linearGradient>
          </defs>
          <g id="chart-grid"></g>
          <path id="chart-area" fill="url(#areaFill)" />
          <path
            id="chart-line"
            fill="none"
            stroke="#3e79ea"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            vector-effect="non-scaling-stroke"
          />
          <g id="chart-dots"></g>
        </svg>
        <div class="chart-x-axis" aria-hidden="true">
          <span>Start</span>
          <span id="chart-x-mid"></span>
          <span>Maturity</span>
        </div>
      </div>
    </div>
  </div>

  <div class="compare-block">
    <div class="schedule-head">
      <p class="heading-sm" style="margin:0">Compare common CD terms</p>
      <span class="muted" style="font-size:12px">Same deposit & rate, different lengths</span>
    </div>
    <div class="table-wrap">
      <table class="data" id="compare-table">
        <thead>
          <tr>
            <th>Term</th>
            <th>Final balance</th>
            <th>Interest</th>
            <th>vs your term</th>
          </tr>
        </thead>
        <tbody id="compare-body"></tbody>
      </table>
    </div>
  </div>

  <div class="schedule">
    <div class="schedule-head">
      <p class="heading-sm" style="margin:0">Growth schedule</p>
      <span class="muted" style="font-size:12px" id="schedule-note">By period</span>
    </div>
    <div class="table-wrap">
      <table class="data" id="schedule-table">
        <thead>
          <tr>
            <th>Period</th>
            <th>Deposit</th>
            <th>Interest</th>
            <th>Balance</th>
          </tr>
        </thead>
        <tbody id="schedule-body"></tbody>
      </table>
    </div>
  </div>
</div>

<style>
  .calc {
    padding: 24px;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .calc-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .calc-form-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .preset-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .preset-row .btn {
    padding: 6px 10px;
    font-size: 12px;
  }

  .calc-results {
    background: linear-gradient(180deg, #f0f5fe 0%, #ffffff 100%);
    border: 1px solid var(--color-pale-slate);
    border-radius: 6px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .result-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-iron);
    margin-bottom: 6px;
  }

  .result-value {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 48px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--color-ink);
  }

  .result-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .result-mid {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-ink);
  }

  .result-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .result-note {
    margin: 0;
    font-size: 12px;
    color: var(--color-graphite);
    line-height: 1.45;
  }

  .chart-block,
  .compare-block,
  .schedule {
    margin-top: 28px;
  }

  .schedule-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .chart-wrap {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 10px;
    border: 1px solid var(--color-pale-slate);
    border-radius: 6px;
    padding: 16px 16px 12px;
    background: var(--color-pure-white);
  }

  .chart-y-axis {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-end;
    padding: 4px 0 28px;
    min-width: 4.5rem;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    color: var(--color-graphite);
    -webkit-font-smoothing: antialiased;
  }

  .chart-main {
    min-width: 0;
  }

  .chart-main svg {
    width: 100%;
    height: auto;
    aspect-ratio: 800 / 280;
    display: block;
    overflow: visible;
  }

  .chart-x-axis {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 6px;
    padding: 0 2px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-graphite);
    -webkit-font-smoothing: antialiased;
  }

  @media (max-width: 520px) {
    .chart-y-axis {
      min-width: 3.25rem;
      font-size: 10px;
    }
  }

  tr.is-current td {
    background: rgba(137, 236, 176, 0.12);
    font-weight: 500;
  }

  @media (max-width: 800px) {
    .calc-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>

<script>
  type Compounding =
    | 'daily'
    | 'monthly'
    | 'quarterly'
    | 'semiannually'
    | 'annually'
    | 'continuous';

  type Row = { label: string; deposit: number; interest: number; balance: number };
  type CompareRow = {
    months: number;
    term: string;
    balance: number;
    interest: number;
    deltaLabel: string;
    isCurrent: boolean;
  };

  const N: Record<Exclude<Compounding, 'continuous'>, number> = {
    daily: 365,
    monthly: 12,
    quarterly: 4,
    semiannually: 2,
    annually: 1,
  };

  const COMPARE_TERMS = [3, 6, 12, 24, 36, 60];

  const COMPOUNDING_LABEL: Record<Compounding, string> = {
    daily: 'Daily',
    monthly: 'Monthly',
    quarterly: 'Quarterly',
    semiannually: 'Semi-annually',
    annually: 'Annually',
    continuous: 'Continuous',
  };

  let lastExport = {
    principal: 0,
    ratePercent: 0,
    rateIsApy: true,
    compounding: 'daily' as Compounding,
    termMonths: 0,
    monthlyDeposit: 0,
    balance: 0,
    interest: 0,
    deposits: 0,
    apy: 0,
    points: [] as number[],
    scheduleRows: [] as Row[],
    scheduleNote: 'By period',
    compareRows: [] as CompareRow[],
  };

  function nominalRate(ratePercent: number, rateIsApy: boolean, compounding: Compounding): number {
    const r = ratePercent / 100;
    if (!rateIsApy) return r;
    if (compounding === 'continuous') return Math.log(1 + r);
    const n = N[compounding];
    return n * (Math.pow(1 + r, 1 / n) - 1);
  }

  function compoundAmount(principal: number, nominal: number, compounding: Compounding, years: number): number {
    if (years <= 0) return principal;
    if (compounding === 'continuous') return principal * Math.exp(nominal * years);
    const n = N[compounding as Exclude<Compounding, 'continuous'>] ?? 12;
    return principal * Math.pow(1 + nominal / n, n * years);
  }

  function monthlyGrowth(nominal: number, compounding: Compounding): number {
    if (compounding === 'continuous') return Math.exp(nominal / 12) - 1;
    const n = N[compounding as Exclude<Compounding, 'continuous'>] ?? 12;
    return Math.pow(1 + nominal / n, n / 12) - 1;
  }

  function formatMoney(n: number): string {
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 2,
    }).format(n || 0);
  }

  function formatPercent(n: number): string {
    return `${((n || 0) * 100).toFixed(2)}%`;
  }

  function termLabel(termMonths: number): string {
    const years = Math.floor(termMonths / 12);
    const months = Math.round(termMonths % 12);
    let label = '';
    if (years > 0) label += `${years} yr`;
    if (months > 0) label += `${years > 0 ? ' ' : ''}${months} mo`;
    return label || '—';
  }

  function project(
    principal: number,
    ratePercent: number,
    rateIsApy: boolean,
    compounding: Compounding,
    termMonths: number,
    monthlyDeposit: number,
  ): { finalBalance: number; totalInterest: number; totalDeposits: number; rows: Row[]; points: number[] } {
    const years = termMonths / 12;
    const nominal = nominalRate(ratePercent, rateIsApy, compounding);
    const points: number[] = [principal];

    if (termMonths <= 0) {
      return { finalBalance: principal, totalInterest: 0, totalDeposits: principal, rows: [], points };
    }

    if (monthlyDeposit === 0) {
      const finalBalance = compoundAmount(principal, nominal, compounding, years);
      const totalInterest = finalBalance - principal;
      const rows: Row[] = [];
      const step = termMonths <= 24 ? 1 : Math.max(1, Math.floor(termMonths / 12));
      if (termMonths <= 24) {
        for (let m = 1; m <= termMonths; m++) {
          const bal = compoundAmount(principal, nominal, compounding, m / 12);
          const prev = m === 1 ? principal : compoundAmount(principal, nominal, compounding, (m - 1) / 12);
          rows.push({ label: `Month ${m}`, deposit: 0, interest: bal - prev, balance: bal });
          points.push(bal);
        }
      } else {
        const yearCount = Math.ceil(termMonths / 12);
        for (let y = 1; y <= yearCount; y++) {
          const months = Math.min(y * 12, termMonths);
          const bal = compoundAmount(principal, nominal, compounding, months / 12);
          const prevMonths = Math.min((y - 1) * 12, termMonths);
          const prev = y === 1 ? principal : compoundAmount(principal, nominal, compounding, prevMonths / 12);
          rows.push({ label: `Year ${y}`, deposit: 0, interest: bal - prev, balance: bal });
          // denser chart points monthly for longer terms
        }
        for (let m = 1; m <= termMonths; m++) {
          points.push(compoundAmount(principal, nominal, compounding, m / 12));
        }
        if (rows.length) rows[rows.length - 1].balance = finalBalance;
      }
      return { finalBalance, totalInterest, totalDeposits: principal, rows, points };
    }

    let balance = principal;
    let totalDeposits = principal;
    const g = monthlyGrowth(nominal, compounding);
    const rows: Row[] = [];
    for (let m = 1; m <= Math.floor(termMonths); m++) {
      const before = balance;
      balance = balance * (1 + g);
      const interest = balance - before;
      balance += monthlyDeposit;
      totalDeposits += monthlyDeposit;
      rows.push({ label: `Month ${m}`, deposit: monthlyDeposit, interest, balance });
      points.push(balance);
    }
    const rem = termMonths - Math.floor(termMonths);
    if (rem > 0.001) {
      const before = balance;
      if (compounding === 'continuous') balance = balance * Math.exp(nominal * (rem / 12));
      else balance = balance * Math.pow(1 + g, rem);
      rows.push({
        label: `Month ${Math.ceil(termMonths)}`,
        deposit: 0,
        interest: balance - before,
        balance,
      });
      points.push(balance);
    }

    let displayRows = rows;
    if (rows.length > 24) {
      const map = new Map<number, Row>();
      rows.forEach((r, i) => {
        const year = Math.ceil((i + 1) / 12);
        const ex = map.get(year);
        if (!ex) map.set(year, { label: `Year ${year}`, deposit: r.deposit, interest: r.interest, balance: r.balance });
        else {
          ex.deposit += r.deposit;
          ex.interest += r.interest;
          ex.balance = r.balance;
        }
      });
      displayRows = [...map.values()];
    }

    return {
      finalBalance: balance,
      totalInterest: balance - totalDeposits,
      totalDeposits,
      rows: displayRows,
      points,
    };
  }

  function formatAxisMoney(n: number): string {
    if (!Number.isFinite(n)) return '—';
    const abs = Math.abs(n);
    if (abs >= 1_000_000) return `$${(n / 1_000_000).toFixed(2)}M`;
    if (abs >= 10_000) return `$${Math.round(n).toLocaleString('en-US')}`;
    return formatMoney(n);
  }

  /** Downsample long series so the path stays smooth and crisp. */
  function samplePoints(points: number[], maxPoints = 96): number[] {
    if (points.length <= maxPoints) return points;
    const out: number[] = [];
    const last = points.length - 1;
    for (let i = 0; i < maxPoints; i++) {
      const idx = Math.round((i / (maxPoints - 1)) * last);
      out.push(points[idx]);
    }
    return out;
  }

  function renderChart(points: number[]) {
    const line = document.getElementById('chart-line') as SVGPathElement | null;
    const area = document.getElementById('chart-area') as SVGPathElement | null;
    const grid = document.getElementById('chart-grid');
    const dots = document.getElementById('chart-dots');
    const yMaxEl = document.getElementById('chart-y-max');
    const yMidEl = document.getElementById('chart-y-mid');
    const yMinEl = document.getElementById('chart-y-min');
    if (!line || !area || !grid || !dots || !yMaxEl || !yMidEl || !yMinEl) return;

    if (!points.length) {
      line.setAttribute('d', '');
      area.setAttribute('d', '');
      grid.innerHTML = '';
      dots.innerHTML = '';
      return;
    }

    const series = samplePoints(points);
    const padL = 8;
    const padR = 12;
    const padT = 16;
    const padB = 16;
    const w = 800 - padL - padR;
    const h = 280 - padT - padB;
    let min = Math.min(...series);
    let max = Math.max(...series);
    // Small padding so a flat line isn't glued to the edge
    if (max === min) {
      min = min * 0.98;
      max = max * 1.02 || 1;
    } else {
      const pad = (max - min) * 0.08;
      min -= pad;
      max += pad;
    }
    const span = max - min;

    // Horizontal grid (4 bands)
    const gridLines: string[] = [];
    for (let i = 0; i <= 4; i++) {
      const y = padT + (h * i) / 4;
      gridLines.push(
        `<line x1="${padL}" y1="${y.toFixed(2)}" x2="${(padL + w).toFixed(2)}" y2="${y.toFixed(2)}" stroke="#e3e8ea" stroke-width="1" vector-effect="non-scaling-stroke" />`,
      );
    }
    // Left baseline
    gridLines.push(
      `<line x1="${padL}" y1="${padT}" x2="${padL}" y2="${(padT + h).toFixed(2)}" stroke="#e3e8ea" stroke-width="1" vector-effect="non-scaling-stroke" />`,
    );
    grid.innerHTML = gridLines.join('');

    const coords = series.map((p, i) => {
      const x = padL + (i / Math.max(series.length - 1, 1)) * w;
      const y = padT + h - ((p - min) / span) * h;
      return [x, y] as const;
    });

    // Smooth-looking polyline with high precision (no non-uniform stretch)
    const lineD = coords
      .map((c, i) => `${i === 0 ? 'M' : 'L'}${c[0].toFixed(2)},${c[1].toFixed(2)}`)
      .join(' ');
    const baseY = (padT + h).toFixed(2);
    const areaD =
      lineD +
      ` L${coords[coords.length - 1][0].toFixed(2)},${baseY}` +
      ` L${coords[0][0].toFixed(2)},${baseY} Z`;

    line.setAttribute('d', lineD);
    area.setAttribute('d', areaD);

    const start = coords[0];
    const end = coords[coords.length - 1];
    dots.innerHTML = `
      <circle cx="${start[0].toFixed(2)}" cy="${start[1].toFixed(2)}" r="4" fill="#ffffff" stroke="#3e79ea" stroke-width="2" vector-effect="non-scaling-stroke" />
      <circle cx="${end[0].toFixed(2)}" cy="${end[1].toFixed(2)}" r="4.5" fill="#3e79ea" stroke="#ffffff" stroke-width="2" vector-effect="non-scaling-stroke" />
    `;

    const dataMin = Math.min(...points);
    const dataMax = Math.max(...points);
    const dataMid = (dataMin + dataMax) / 2;
    yMaxEl.textContent = formatAxisMoney(dataMax);
    yMidEl.textContent = formatAxisMoney(dataMid);
    yMinEl.textContent = formatAxisMoney(dataMin);
  }

  function renderCompare(
    principal: number,
    ratePercent: number,
    rateIsApy: boolean,
    compounding: Compounding,
    currentMonths: number,
    monthlyDeposit: number,
    currentBalance: number,
  ) {
    const tbody = document.getElementById('compare-body');
    if (!tbody) return;

    const terms = [...new Set([...COMPARE_TERMS, Math.round(currentMonths)].filter((t) => t > 0))].sort(
      (a, b) => a - b,
    );

    tbody.innerHTML = terms
      .map((months) => {
        const r = project(principal, ratePercent, rateIsApy, compounding, months, monthlyDeposit);
        const delta = r.finalBalance - currentBalance;
        const deltaStr =
          Math.abs(delta) < 0.005
            ? 'Current'
            : delta > 0
              ? `+${formatMoney(delta)}`
              : formatMoney(delta);
        const currentClass = months === Math.round(currentMonths) ? ' class="is-current"' : '';
        return `<tr${currentClass}>
          <td>${termLabel(months)}</td>
          <td>${formatMoney(r.finalBalance)}</td>
          <td>${formatMoney(r.totalInterest)}</td>
          <td>${deltaStr}</td>
        </tr>`;
      })
      .join('');
  }

  function calculate() {
    const principal = Math.max(0, parseFloat((document.getElementById('principal') as HTMLInputElement).value) || 0);
    const ratePercent = Math.max(0, parseFloat((document.getElementById('rate') as HTMLInputElement).value) || 0);
    const rateIsApy = (document.getElementById('rateType') as HTMLSelectElement).value === 'apy';
    const term = Math.max(0, parseFloat((document.getElementById('term') as HTMLInputElement).value) || 0);
    const termUnit = (document.getElementById('termUnit') as HTMLSelectElement).value;
    const compounding = (document.getElementById('compounding') as HTMLSelectElement).value as Compounding;
    const monthlyDeposit = Math.max(
      0,
      parseFloat((document.getElementById('monthlyDeposit') as HTMLInputElement).value) || 0,
    );
    const termMonths = termUnit === 'years' ? term * 12 : term;

    const result = project(principal, ratePercent, rateIsApy, compounding, termMonths, monthlyDeposit);
    const years = termMonths / 12;
    const effectiveApy =
      result.totalDeposits > 0 && years > 0
        ? Math.pow(result.finalBalance / result.totalDeposits, 1 / years) - 1
        : 0;

    const scheduleNote =
      result.rows.length && result.rows[0].label.startsWith('Year') ? 'Yearly summary' : 'Monthly schedule';

    const terms = [...new Set([...COMPARE_TERMS, Math.round(termMonths)].filter((t) => t > 0))].sort(
      (a, b) => a - b,
    );
    const compareRows: CompareRow[] = terms.map((months) => {
      const r = project(principal, ratePercent, rateIsApy, compounding, months, monthlyDeposit);
      const delta = r.finalBalance - result.finalBalance;
      const deltaLabel =
        Math.abs(delta) < 0.005 ? 'Current' : delta > 0 ? `+${formatMoney(delta)}` : formatMoney(delta);
      return {
        months,
        term: termLabel(months),
        balance: r.finalBalance,
        interest: r.totalInterest,
        deltaLabel,
        isCurrent: months === Math.round(termMonths),
      };
    });

    lastExport = {
      principal,
      ratePercent,
      rateIsApy,
      compounding,
      termMonths,
      monthlyDeposit,
      balance: result.finalBalance,
      interest: result.totalInterest,
      deposits: result.totalDeposits,
      apy: Math.max(0, effectiveApy),
      points: result.points,
      scheduleRows: result.rows,
      scheduleNote,
      compareRows,
    };

    (document.getElementById('out-balance') as HTMLElement).textContent = formatMoney(result.finalBalance);
    (document.getElementById('out-interest') as HTMLElement).textContent = formatMoney(result.totalInterest);
    (document.getElementById('out-deposits') as HTMLElement).textContent = formatMoney(result.totalDeposits);
    (document.getElementById('out-apy') as HTMLElement).textContent = formatPercent(lastExport.apy);
    (document.getElementById('out-term') as HTMLElement).textContent = termLabel(termMonths);

    const tbody = document.getElementById('schedule-body') as HTMLElement;
    tbody.innerHTML = result.rows
      .map(
        (r) => `<tr>
        <td>${r.label}</td>
        <td>${formatMoney(r.deposit)}</td>
        <td>${formatMoney(r.interest)}</td>
        <td>${formatMoney(r.balance)}</td>
      </tr>`,
      )
      .join('');

    (document.getElementById('schedule-note') as HTMLElement).textContent = scheduleNote;

    renderChart(result.points);
    renderCompare(principal, ratePercent, rateIsApy, compounding, termMonths, monthlyDeposit, result.finalBalance);
  }

  function resultLines(): string[] {
    const s = lastExport;
    return [
      'Nestfigure CD Calculator results',
      `Deposit: ${formatMoney(s.principal)}`,
      `Rate: ${s.ratePercent.toFixed(2)}% ${s.rateIsApy ? 'APY' : 'nominal APR'}`,
      `Term: ${termLabel(s.termMonths)}`,
      `Compounding: ${COMPOUNDING_LABEL[s.compounding]}`,
      s.monthlyDeposit > 0 ? `Monthly deposit: ${formatMoney(s.monthlyDeposit)}` : '',
      `Final balance: ${formatMoney(s.balance)}`,
      `Interest earned: ${formatMoney(s.interest)}`,
      `Total deposited: ${formatMoney(s.deposits)}`,
      `Effective APY: ${formatPercent(s.apy)}`,
      'Estimates only - not a bank quote.',
      'https://nestfigure.com/cd-calculator/',
    ].filter((line) => line.length > 0);
  }

  function setActionStatus(message: string, ms = 2000) {
    const status = document.getElementById('copy-status');
    if (!status) return;
    status.hidden = false;
    status.textContent = message;
    window.setTimeout(() => {
      status.hidden = true;
    }, ms);
  }

  async function copyResults() {
    const text = resultLines().join('\n');
    try {
      await navigator.clipboard.writeText(text);
      setActionStatus('Copied to clipboard.');
    } catch {
      setActionStatus('Could not copy — select and copy manually.', 4000);
    }
  }

  /** Vector multi-page report PDF (chart + tables) — no external library. */
  function buildReportPdf(): Blob {
    const PAGE_W = 612;
    const PAGE_H = 792;
    const M = 40;
    const BLUE = [0.145, 0.388, 0.922] as const; // #2563eb
    const INK = [0.102, 0.122, 0.141] as const;
    const MUTED = [0.36, 0.42, 0.46] as const;
    const LINE = [0.89, 0.91, 0.92] as const;
    const LAVENDER = [0.941, 0.961, 0.996] as const;
    const WHITE = [1, 1, 1] as const;
    const ZEBRA = [0.98, 0.985, 0.99] as const;

    const pdfText = (value: string) =>
      value
        .replace(/[—–−]/g, '-')
        .replace(/[^\x20-\x7E]/g, '')
        .replace(/\\/g, '\\\\')
        .replace(/\(/g, '\\(')
        .replace(/\)/g, '\\)');

    const pages: string[] = [];
    let ops: string[] = [];
    let yTop = M;

    const flushPage = () => {
      const pageNo = pages.length + 1;
      ops.push(
        `${MUTED[0]} ${MUTED[1]} ${MUTED[2]} rg`,
        'BT',
        '/F1 8 Tf',
        `1 0 0 1 ${M} 22 Tm`,
        `(nestfigure.com/cd-calculator  |  Educational estimate only - not a bank quote) Tj`,
        'ET',
        'BT',
        '/F1 8 Tf',
        `1 0 0 1 ${PAGE_W - M - 50} 22 Tm`,
        `(Page ${pageNo}) Tj`,
        'ET',
      );
      pages.push(ops.join('\n'));
      ops = [];
      yTop = M + 8;
    };

    const ensure = (need: number) => {
      if (yTop + need > PAGE_H - 40) flushPage();
    };

    const py = (top: number) => PAGE_H - top; // convert top-down to PDF y

    const fillRect = (x: number, top: number, w: number, h: number, c: readonly [number, number, number]) => {
      ops.push(`${c[0]} ${c[1]} ${c[2]} rg`, `${x.toFixed(2)} ${(py(top) - h).toFixed(2)} ${w.toFixed(2)} ${h.toFixed(2)} re`, 'f');
    };

    const strokeRect = (
      x: number,
      top: number,
      w: number,
      h: number,
      c: readonly [number, number, number],
      lw = 0.75,
    ) => {
      ops.push(
        `${c[0]} ${c[1]} ${c[2]} RG`,
        `${lw} w`,
        `${x.toFixed(2)} ${(py(top) - h).toFixed(2)} ${w.toFixed(2)} ${h.toFixed(2)} re`,
        'S',
      );
    };

    const line = (
      x1: number,
      top1: number,
      x2: number,
      top2: number,
      c: readonly [number, number, number],
      lw = 0.75,
    ) => {
      ops.push(
        `${c[0]} ${c[1]} ${c[2]} RG`,
        `${lw} w`,
        `${x1.toFixed(2)} ${py(top1).toFixed(2)} m`,
        `${x2.toFixed(2)} ${py(top2).toFixed(2)} l`,
        'S',
      );
    };

    const textAt = (
      str: string,
      x: number,
      top: number,
      size: number,
      opts: {
        bold?: boolean;
        color?: readonly [number, number, number];
        align?: 'left' | 'right' | 'center';
        maxWidth?: number;
      } = {},
    ) => {
      const font = opts.bold ? '/F2' : '/F1';
      const color = opts.color || INK;
      let drawX = x;
      // Approximate Helvetica width ~0.5 * size per char for alignment
      const approxW = pdfText(str).length * size * 0.5;
      if (opts.align === 'right') drawX = x - approxW;
      if (opts.align === 'center') drawX = x - approxW / 2;
      ops.push(
        `${color[0]} ${color[1]} ${color[2]} rg`,
        'BT',
        `${font} ${size} Tf`,
        `1 0 0 1 ${drawX.toFixed(2)} ${(py(top) - size * 0.8).toFixed(2)} Tm`,
        `(${pdfText(str)}) Tj`,
        'ET',
      );
    };

    const s = lastExport;
    const contentW = PAGE_W - M * 2;
    const dateStr = new Date().toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });

    // —— Header band ——
    fillRect(0, 0, PAGE_W, 56, BLUE);
    textAt('Nestfigure', M, 22, 14, { bold: true, color: WHITE });
    textAt('CD Calculator Report', M, 40, 10, { color: WHITE });
    textAt(dateStr, PAGE_W - M, 32, 9, { color: WHITE, align: 'right' });
    yTop = 72;

    // —— Title + inputs ——
    textAt('Your CD estimate', M, yTop, 16, { bold: true });
    yTop += 22;
    const inputBits = [
      `Deposit ${formatMoney(s.principal)}`,
      `${s.ratePercent.toFixed(2)}% ${s.rateIsApy ? 'APY' : 'nominal APR'}`,
      termLabel(s.termMonths),
      `${COMPOUNDING_LABEL[s.compounding]} compounding`,
    ];
    if (s.monthlyDeposit > 0) inputBits.push(`+${formatMoney(s.monthlyDeposit)}/mo`);
    textAt(inputBits.join('  ·  '), M, yTop, 9, { color: MUTED });
    yTop += 18;

    // —— Metric cards ——
    const cardH = 48;
    const gap = 8;
    // Big balance card
    fillRect(M, yTop, contentW, 56, LAVENDER);
    strokeRect(M, yTop, contentW, 56, LINE, 0.6);
    textAt('FINAL BALANCE', M + 14, yTop + 16, 8, { color: MUTED, bold: true });
    textAt(formatMoney(s.balance), M + 14, yTop + 36, 20, { bold: true, color: BLUE });
    yTop += 56 + gap;

    const miniW = (contentW - gap * 3) / 4;
    const minis = [
      { label: 'INTEREST EARNED', value: formatMoney(s.interest) },
      { label: 'TOTAL DEPOSITED', value: formatMoney(s.deposits) },
      { label: 'EFFECTIVE APY', value: formatPercent(s.apy) },
      { label: 'TERM', value: termLabel(s.termMonths) },
    ];
    minis.forEach((card, i) => {
      const x = M + i * (miniW + gap);
      fillRect(x, yTop, miniW, cardH, WHITE);
      strokeRect(x, yTop, miniW, cardH, LINE, 0.6);
      textAt(card.label, x + 10, yTop + 14, 7, { color: MUTED, bold: true });
      textAt(card.value, x + 10, yTop + 32, 11, { bold: true });
    });
    yTop += cardH + 20;

    // —— Growth chart ——
    ensure(210);
    textAt('Balance over time', M, yTop, 12, { bold: true });
    yTop += 6;
    textAt('Projected balance from start to maturity', M, yTop + 12, 8, { color: MUTED });
    yTop += 24;

    const chartH = 160;
    const chartPadL = 52;
    const chartPadR = 12;
    const chartPadT = 10;
    const chartPadB = 22;
    const chartBoxW = contentW;
    const chartBoxH = chartH;
    fillRect(M, yTop, chartBoxW, chartBoxH, WHITE);
    strokeRect(M, yTop, chartBoxW, chartBoxH, LINE, 0.7);

    const plotX = M + chartPadL;
    const plotTop = yTop + chartPadT;
    const plotW = chartBoxW - chartPadL - chartPadR;
    const plotH = chartBoxH - chartPadT - chartPadB;
    const pts = s.points.length ? s.points : [s.principal, s.balance];
    const minV = Math.min(...pts);
    const maxV = Math.max(...pts);
    const span = Math.max(maxV - minV, 1);

    // grid + y labels
    for (let g = 0; g <= 4; g++) {
      const t = g / 4;
      const gy = plotTop + plotH * t;
      line(plotX, gy, plotX + plotW, gy, LINE, 0.5);
      const val = maxV - span * t;
      textAt(formatMoney(val), plotX - 6, gy + 3, 7, { color: MUTED, align: 'right' });
    }

    // area + line path
    const coords = pts.map((p, i) => {
      const x = plotX + (i / Math.max(pts.length - 1, 1)) * plotW;
      const top = plotTop + ((maxV - p) / span) * plotH;
      return { x, top };
    });

    if (coords.length > 1) {
      // filled area under the curve (solid soft blue — no alpha dependency)
      const baseTop = plotTop + plotH;
      let area = `${coords[0].x.toFixed(2)} ${py(coords[0].top).toFixed(2)} m`;
      for (let i = 1; i < coords.length; i++) {
        area += ` ${coords[i].x.toFixed(2)} ${py(coords[i].top).toFixed(2)} l`;
      }
      area += ` ${coords[coords.length - 1].x.toFixed(2)} ${py(baseTop).toFixed(2)} l`;
      area += ` ${coords[0].x.toFixed(2)} ${py(baseTop).toFixed(2)} l f`;
      ops.push('0.88 0.92 0.99 rg', area);

      let path = `${coords[0].x.toFixed(2)} ${py(coords[0].top).toFixed(2)} m`;
      for (let i = 1; i < coords.length; i++) {
        path += ` ${coords[i].x.toFixed(2)} ${py(coords[i].top).toFixed(2)} l`;
      }
      ops.push(`${BLUE[0]} ${BLUE[1]} ${BLUE[2]} RG`, '1.8 w', '1 J', '1 j', path, 'S');

      // end dots
      const dot = (c: { x: number; top: number }, r: number, fill: readonly [number, number, number]) => {
        const cx = c.x;
        const cy = py(c.top);
        // circle via four Beziers
        const k = 0.5522847498 * r;
        ops.push(
          `${fill[0]} ${fill[1]} ${fill[2]} rg`,
          `${(cx + r).toFixed(2)} ${cy.toFixed(2)} m`,
          `${(cx + r).toFixed(2)} ${(cy + k).toFixed(2)} ${(cx + k).toFixed(2)} ${(cy + r).toFixed(2)} ${cx.toFixed(2)} ${(cy + r).toFixed(2)} c`,
          `${(cx - k).toFixed(2)} ${(cy + r).toFixed(2)} ${(cx - r).toFixed(2)} ${(cy + k).toFixed(2)} ${(cx - r).toFixed(2)} ${cy.toFixed(2)} c`,
          `${(cx - r).toFixed(2)} ${(cy - k).toFixed(2)} ${(cx - k).toFixed(2)} ${(cy - r).toFixed(2)} ${cx.toFixed(2)} ${(cy - r).toFixed(2)} c`,
          `${(cx + k).toFixed(2)} ${(cy - r).toFixed(2)} ${(cx + r).toFixed(2)} ${(cy - k).toFixed(2)} ${(cx + r).toFixed(2)} ${cy.toFixed(2)} c`,
          'f',
        );
      };
      dot(coords[0], 3, WHITE);
      ops.push(`${BLUE[0]} ${BLUE[1]} ${BLUE[2]} RG`, '1.2 w');
      // outline start
      const c0 = coords[0];
      ops.push(
        `${(c0.x + 3).toFixed(2)} ${py(c0.top).toFixed(2)} m`,
        `${(c0.x + 3).toFixed(2)} ${(py(c0.top) + 1.65).toFixed(2)} ${(c0.x + 1.65).toFixed(2)} ${(py(c0.top) + 3).toFixed(2)} ${c0.x.toFixed(2)} ${(py(c0.top) + 3).toFixed(2)} c`,
        `${(c0.x - 1.65).toFixed(2)} ${(py(c0.top) + 3).toFixed(2)} ${(c0.x - 3).toFixed(2)} ${(py(c0.top) + 1.65).toFixed(2)} ${(c0.x - 3).toFixed(2)} ${py(c0.top).toFixed(2)} c`,
        `${(c0.x - 3).toFixed(2)} ${(py(c0.top) - 1.65).toFixed(2)} ${(c0.x - 1.65).toFixed(2)} ${(py(c0.top) - 3).toFixed(2)} ${c0.x.toFixed(2)} ${(py(c0.top) - 3).toFixed(2)} c`,
        `${(c0.x + 1.65).toFixed(2)} ${(py(c0.top) - 3).toFixed(2)} ${(c0.x + 3).toFixed(2)} ${(py(c0.top) - 1.65).toFixed(2)} ${(c0.x + 3).toFixed(2)} ${py(c0.top).toFixed(2)} c`,
        'S',
      );
      dot(coords[coords.length - 1], 3.5, BLUE);
    }

    textAt('Start', plotX, yTop + chartBoxH - 8, 8, { color: MUTED });
    textAt('Maturity', plotX + plotW, yTop + chartBoxH - 8, 8, { color: MUTED, align: 'right' });
    yTop += chartBoxH + 22;

    // —— Tables ——
    const drawTable = (
      title: string,
      subtitle: string,
      headers: string[],
      rows: string[][],
      colFrac: number[],
      highlightRows: boolean[] = [],
    ) => {
      ensure(56);
      textAt(title, M, yTop, 12, { bold: true });
      yTop += 6;
      textAt(subtitle, M, yTop + 12, 8, { color: MUTED });
      yTop += 22;

      const rowH = 18;
      const headH = 20;
      const widths = colFrac.map((f) => f * contentW);
      let tableTop = yTop;

      const drawHeader = () => {
        fillRect(M, yTop, contentW, headH, BLUE);
        let x = M;
        headers.forEach((h, i) => {
          textAt(h, x + 8, yTop + 13, 8, { bold: true, color: WHITE });
          x += widths[i];
        });
        yTop += headH;
      };

      const closeTableBorder = (fromTop: number) => {
        const h = yTop - fromTop;
        if (h > 0) strokeRect(M, fromTop, contentW, h, LINE, 0.7);
      };

      drawHeader();

      rows.forEach((row, ri) => {
        if (yTop + rowH > PAGE_H - 40) {
          closeTableBorder(tableTop);
          flushPage();
          textAt(`${title} (continued)`, M, yTop, 11, { bold: true });
          yTop += 16;
          tableTop = yTop;
          drawHeader();
        }
        const hi = highlightRows[ri];
        if (hi) fillRect(M, yTop, contentW, rowH, LAVENDER);
        else if (ri % 2 === 1) fillRect(M, yTop, contentW, rowH, ZEBRA);
        let x = M;
        row.forEach((cell, i) => {
          const isMoney = i > 0;
          if (isMoney) {
            textAt(cell, x + widths[i] - 8, yTop + 12, 8, { align: 'right', color: INK });
          } else {
            textAt(cell, x + 8, yTop + 12, 8, { bold: !!hi, color: INK });
          }
          x += widths[i];
        });
        line(M, yTop + rowH, M + contentW, yTop + rowH, LINE, 0.4);
        yTop += rowH;
      });
      closeTableBorder(tableTop);
      yTop += 18;
    };

    drawTable(
      'Compare common CD terms',
      'Same deposit and rate, different lengths',
      ['Term', 'Final balance', 'Interest', 'vs your term'],
      s.compareRows.map((r) => [r.term, formatMoney(r.balance), formatMoney(r.interest), r.deltaLabel]),
      [0.18, 0.3, 0.26, 0.26],
      s.compareRows.map((r) => r.isCurrent),
    );

    drawTable(
      'Growth schedule',
      s.scheduleNote,
      ['Period', 'Deposit', 'Interest', 'Balance'],
      s.scheduleRows.map((r) => [r.label, formatMoney(r.deposit), formatMoney(r.interest), formatMoney(r.balance)]),
      [0.22, 0.26, 0.26, 0.26],
    );

    // Disclaimer box
    ensure(70);
    fillRect(M, yTop, contentW, 54, LAVENDER);
    strokeRect(M, yTop, contentW, 54, LINE, 0.6);
    textAt('Disclaimer', M + 12, yTop + 14, 8, { bold: true, color: MUTED });
    textAt(
      'Illustrative estimate only. Not financial advice. Actual bank CD rates, compounding,',
      M + 12,
      yTop + 28,
      8,
      { color: INK },
    );
    textAt(
      'day-count methods, and early withdrawal penalties vary. Always read the institution disclosures.',
      M + 12,
      yTop + 40,
      8,
      { color: INK },
    );
    yTop += 62;
    textAt('Generated by Nestfigure  ·  https://nestfigure.com/cd-calculator/', M, yTop, 8, { color: MUTED });

    flushPage();

    // Build PDF file
    const objects: string[] = [];
    // 1 catalog, 2 pages, 3..2+n pages, then contents, then fonts
    const pageCount = pages.length;
    const pageObjIds: number[] = [];
    const contentObjIds: number[] = [];

    // We'll assign IDs: 1=Catalog, 2=Pages, 3..2+pageCount=Page, then contents, then fonts
    let nextId = 3;
    for (let i = 0; i < pageCount; i++) pageObjIds.push(nextId++);
    for (let i = 0; i < pageCount; i++) contentObjIds.push(nextId++);
    const fontRegId = nextId++;
    const fontBoldId = nextId++;

    objects.push(''); // placeholder index 0 unused - we'll use map by id
    const objMap = new Map<number, string>();

    objMap.set(1, `<< /Type /Catalog /Pages 2 0 R >>`);
    objMap.set(
      2,
      `<< /Type /Pages /Kids [${pageObjIds.map((id) => `${id} 0 R`).join(' ')}] /Count ${pageCount} >>`,
    );

    for (let i = 0; i < pageCount; i++) {
      objMap.set(
        pageObjIds[i],
        `<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ${PAGE_W} ${PAGE_H}] /Contents ${contentObjIds[i]} 0 R /Resources << /Font << /F1 ${fontRegId} 0 R /F2 ${fontBoldId} 0 R >> >> >>`,
      );
      const stream = pages[i];
      objMap.set(contentObjIds[i], `<< /Length ${stream.length} >>\nstream\n${stream}\nendstream`);
    }
    objMap.set(fontRegId, `<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica >>`);
    objMap.set(fontBoldId, `<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold >>`);

    let pdf = '%PDF-1.4\n';
    const offsets = [0];
    const maxId = fontBoldId;
    for (let id = 1; id <= maxId; id++) {
      offsets[id] = pdf.length;
      pdf += `${id} 0 obj\n${objMap.get(id)}\nendobj\n`;
    }
    const xrefStart = pdf.length;
    pdf += `xref\n0 ${maxId + 1}\n`;
    pdf += '0000000000 65535 f \n';
    for (let id = 1; id <= maxId; id++) {
      pdf += `${String(offsets[id]).padStart(10, '0')} 00000 n \n`;
    }
    pdf += `trailer\n<< /Size ${maxId + 1} /Root 1 0 R >>\nstartxref\n${xrefStart}\n%%EOF`;
    return new Blob([pdf], { type: 'application/pdf' });
  }

  function exportPdf() {
    try {
      const blob = buildReportPdf();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      const stamp = new Date().toISOString().slice(0, 10);
      a.href = url;
      a.download = `nestfigure-cd-results-${stamp}.pdf`;
      a.rel = 'noopener';
      document.body.appendChild(a);
      a.click();
      a.remove();
      window.setTimeout(() => URL.revokeObjectURL(url), 1000);
      setActionStatus('PDF report downloaded.');
    } catch {
      setActionStatus('Could not create PDF. Try Copy results instead.', 4000);
    }
  }

  function bind() {
    const form = document.getElementById('cd-form');
    if (!form) return;
    form.addEventListener('input', calculate);
    form.addEventListener('change', calculate);
    document.querySelectorAll('.preset').forEach((btn) => {
      btn.addEventListener('click', () => {
        const months = (btn as HTMLElement).dataset.months || '12';
        (document.getElementById('term') as HTMLInputElement).value = months;
        (document.getElementById('termUnit') as HTMLSelectElement).value = 'months';
        calculate();
      });
    });
    document.getElementById('copy-results')?.addEventListener('click', copyResults);
    document.getElementById('export-pdf')?.addEventListener('click', exportPdf);
    calculate();
  }

  bind();
</script>
