---
/**
 * Worked example matching site copy: $10,000 @ 4.50% APY, 12 months, daily.
 * Final balance $10,450 · interest $450.
 */
interface Props {
  caption?: string;
}
const {
  caption = 'Same example used in the guide and calculator defaults—illustrative, not a bank quote.',
} = Astro.props;
---

<figure class="content-figure data-figure">
  <div
    class="fig-inner"
    role="img"
    aria-label="Worked example: 10000 dollars at 4.5 percent APY for 12 months equals about 450 dollars interest and 10450 dollars final balance"
  >
    <p class="fig-title">Illustrative math · 12-month horizon</p>
    <div class="grid">
      <div class="panel">
        <p class="panel-label">Starting point</p>
        <dl>
          <div><dt>Deposit (P)</dt><dd>$10,000</dd></div>
          <div><dt>Rate</dt><dd>4.50% APY</dd></div>
          <div><dt>Term</dt><dd>12 months</dd></div>
          <div><dt>Compounding</dt><dd>Daily</dd></div>
        </dl>
      </div>
      <div class="panel result">
        <p class="panel-label">Result under stated assumptions</p>
        <div class="big">
          <span class="muted-label">Final balance</span>
          <strong>$10,450.00</strong>
        </div>
        <div class="metrics">
          <div>
            <span class="muted-label">Interest earned</span>
            <strong class="mint">+$450.00</strong>
          </div>
          <div>
            <span class="muted-label">Effective growth</span>
            <strong>4.50%</strong>
          </div>
        </div>
      </div>
    </div>
    <div class="chart" aria-hidden="true">
      <svg viewBox="0 0 320 80" preserveAspectRatio="none">
        <defs>
          <linearGradient id="exFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#3e79ea" stop-opacity="0.25"></stop>
            <stop offset="100%" stop-color="#3e79ea" stop-opacity="0.02"></stop>
          </linearGradient>
        </defs>
        <path
          d="M0 70 L40 66 L80 61 L120 55 L160 48 L200 40 L240 30 L280 18 L320 8 L320 80 L0 80 Z"
          fill="url(#exFill)"></path>
        <path
          d="M0 70 L40 66 L80 61 L120 55 L160 48 L200 40 L240 30 L280 18 L320 8"
          fill="none"
          stroke="#3e79ea"
          stroke-width="2.5"
          stroke-linecap="round"></path>
        <text x="4" y="12" class="svg-t">$10,000</text>
        <text x="250" y="12" class="svg-t">$10,450</text>
      </svg>
      <div class="chart-labels">
        <span>Start</span>
        <span>Month 12 · maturity</span>
      </div>
    </div>
  </div>
  <figcaption set:html={caption} />
</figure>

<style>
  .fig-inner {
    padding: 20px;
    background: #fff;
  }
  .fig-title {
    margin: 0 0 16px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-graphite);
    font-family: var(--font-mono);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .panel {
    border: 1px solid var(--color-pale-slate);
    border-radius: 6px;
    padding: 14px;
    background: #fafcfe;
  }
  .panel.result {
    background: linear-gradient(180deg, #f0f5fe 0%, #ffffff 100%);
    border-color: #c9daf8;
  }
  .panel-label {
    margin: 0 0 12px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-midnight-iris);
  }
  dl {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  dl div {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 13px;
  }
  dt {
    color: var(--color-graphite);
    font-weight: 400;
  }
  dd {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--color-ink);
  }
  .big {
    margin-bottom: 14px;
  }
  .big strong {
    display: block;
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .muted-label {
    display: block;
    font-size: 12px;
    color: var(--color-iron);
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .metrics strong {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
  }
  .mint {
    color: #1a7a45;
  }
  .chart {
    margin-top: 16px;
    border: 1px solid var(--color-pale-slate);
    border-radius: 6px;
    padding: 12px 12px 8px;
    background: #fafcfe;
  }
  .chart svg {
    width: 100%;
    height: 72px;
    display: block;
  }
  .svg-t {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--color-graphite);
  }
  .chart-labels {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--color-graphite);
    margin-top: 4px;
  }
  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
