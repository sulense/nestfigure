---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CD_SCENARIOS } from '../../lib/cdScenarios';
import { RAISE_SCENARIOS } from '../../lib/raiseScenarios';

const title = 'Guides — Nestfigure Personal Finance';
const description =
  'Guides and worked examples for Nestfigure calculators: CD interest and salary raises, with links to official U.S. sources when needed.';

type Card = {
  href: string;
  title: string;
  blurb: string;
  kind: string;
};

type Category = {
  id: string;
  eyebrow: string;
  title: string;
  intro: string;
  toolHref: string;
  toolLabel: string;
  methodHref: string;
  faqHref: string;
  guides: Card[];
  scenarios: Card[];
  extras: Card[];
};

const cdGuides: Card[] = [
  {
    href: '/guides/how-cd-interest-works/',
    title: 'How CD interest works',
    blurb:
      'APY vs interest rate in plain words, how compounding works, and a clear $10,000 example.',
    kind: 'Guide',
  },
  {
    href: '/guides/cd-vs-savings/',
    title: 'CD vs high-yield savings',
    blurb: 'Easy access vs locking money for a term, insurance basics, and how to run your own numbers.',
    kind: 'Guide',
  },
  {
    href: '/guides/cd-early-withdrawal/',
    title: 'CD early withdrawal & penalties',
    blurb: 'What the CFPB says about cashing out early—and what Nestfigure’s calculator does not include.',
    kind: 'Guide',
  },
];

const raiseGuides: Card[] = [
  {
    href: '/guides/how-to-calculate-a-raise/',
    title: 'How to calculate a raise percentage',
    blurb: 'Simple raise formulas, a worked $60,000 / 5% example, and the free raise calculator.',
    kind: 'Guide',
  },
  {
    href: '/guides/hourly-to-salary-raise/',
    title: 'Hourly to annual raise math',
    blurb: 'Turn hourly pay into yearly pay, then apply a raise percent to see the new amounts.',
    kind: 'Guide',
  },
  {
    href: '/guides/raise-vs-bonus/',
    title: 'Raise vs bonus (math only)',
    blurb: 'Base-pay raise vs one-time bonus numbers—Nestfigure does not choose for you.',
    kind: 'Guide',
  },
];

const categories: Category[] = [
  {
    id: 'cd-calculator',
    eyebrow: 'Certificate of deposit',
    title: 'CD Calculator',
    intro:
      'Plain-language guides, worked deposit examples, common questions, and the math behind Nestfigure’s free CD tool.',
    toolHref: '/cd-calculator/',
    toolLabel: 'Open CD Calculator',
    methodHref: '/methodology/cd-calculator/',
    faqHref: '/faq/certificate-of-deposit/',
    guides: cdGuides,
    scenarios: CD_SCENARIOS.map((s) => ({
      href: `/guides/${s.slug}/`,
      title: s.cardTitle,
      blurb: s.cardBlurb,
      kind: 'Example',
    })),
    extras: [
      {
        href: '/faq/certificate-of-deposit/',
        title: 'CD questions',
        blurb:
          'Sample earnings at labeled rates, term length, early withdrawal, insurance basics, and common rate myths.',
        kind: 'Questions',
      },
      {
        href: '/methodology/cd-calculator/',
        title: 'How the CD calculator works',
        blurb: 'The formulas we use, how APY is handled, compounding choices, and what we leave out.',
        kind: 'How we calculate',
      },
    ],
  },
  {
    id: 'raise-calculator',
    eyebrow: 'Salary increase',
    title: 'Raise Calculator',
    intro:
      'Percent and hourly raise guides, sample examples, common questions, and the math behind Nestfigure’s free raise tool.',
    toolHref: '/raise-calculator/',
    toolLabel: 'Open Raise Calculator',
    methodHref: '/methodology/raise-calculator/',
    faqHref: '/faq/raise-calculator/',
    guides: raiseGuides,
    scenarios: RAISE_SCENARIOS.map((s) => ({
      href: `/guides/${s.slug}/`,
      title: s.cardTitle,
      blurb: s.cardBlurb,
      kind: 'Example',
    })),
    extras: [
      {
        href: '/faq/raise-calculator/',
        title: 'Raise questions',
        blurb: 'Percent math, hourly examples, national wage context, taxes, and what the tool will not answer.',
        kind: 'Questions',
      },
      {
        href: '/methodology/raise-calculator/',
        title: 'How the raise calculator works',
        blurb: 'Raise formulas, monthly and weekly pay views, hourly annual pay, and optional tax percent limits.',
        kind: 'How we calculate',
      },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/guides/"
  ogImage="/images/og-default.webp"
>
  <section class="hero">
    <div class="container" style="text-align:center;display:flex;flex-direction:column;align-items:center;">
      <p class="eyebrow">Learn</p>
      <h1 class="display" style="font-size:clamp(36px,5vw,56px);">Guides & examples</h1>
      <p class="lead">
        Short articles and worked examples for each calculator—with clear math and official source links when needed.
      </p>
      <nav class="cat-jump" aria-label="Jump to calculator">
        {
          categories.map((c) => (
            <a class="btn btn-secondary" href={`#${c.id}`}>
              {c.title}
            </a>
          ))
        }
        <a class="btn btn-secondary" href="/faq/">Common questions</a>
        <a class="btn btn-secondary" href="/methodology/">How we calculate</a>
      </nav>
    </div>
  </section>

  {
    categories.map((cat) => (
      <section class="section cat-section" id={cat.id} style="padding-top:0;">
        <div class="container">
          <header class="cat-header">
            <div class="cat-header-copy">
              <p class="eyebrow">{cat.eyebrow}</p>
              <h2 class="heading" style="margin-bottom:8px;">
                {cat.title}
              </h2>
              <p class="cat-intro">{cat.intro}</p>
            </div>
            <div class="cat-header-actions">
              <a class="btn btn-primary" href={cat.toolHref}>
                {cat.toolLabel}
              </a>
              <a class="btn btn-secondary" href={cat.methodHref}>
                How we calculate
              </a>
              <a class="btn btn-secondary" href={cat.faqHref}>
                Questions
              </a>
            </div>
          </header>

          <h3 class="subhead">Guides</h3>
          <div class="guide-grid">
            {cat.guides.map((g) => (
              <a class="card guide-card" href={g.href}>
                <div class="guide-card-body">
                  <span class="pill pill-neutral">{g.kind}</span>
                  <h4 class="heading-sm" style="margin-top:12px;">
                    {g.title}
                  </h4>
                  <p>{g.blurb}</p>
                  <span class="linkish">Read →</span>
                </div>
              </a>
            ))}
          </div>

          <h3 class="subhead">Worked examples</h3>
          <div class="guide-grid">
            {cat.scenarios.map((g) => (
              <a class="card guide-card" href={g.href}>
                <div class="guide-card-body">
                  <span class="pill pill-neutral">{g.kind}</span>
                  <h4 class="heading-sm" style="margin-top:12px;">
                    {g.title}
                  </h4>
                  <p>{g.blurb}</p>
                  <span class="linkish">Read →</span>
                </div>
              </a>
            ))}
          </div>

          <h3 class="subhead">Questions & how we calculate</h3>
          <div class="guide-grid">
            {cat.extras.map((g) => (
              <a class="card guide-card" href={g.href}>
                <div class="guide-card-body">
                  <span class="pill pill-neutral">{g.kind}</span>
                  <h4 class="heading-sm" style="margin-top:12px;">
                    {g.title}
                  </h4>
                  <p>{g.blurb}</p>
                  <span class="linkish">Open →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))
  }
</BaseLayout>

<style>
  .cat-jump {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: 8px;
  }

  .cat-jump .btn {
    font-size: 13px;
    padding: 8px 14px;
  }

  .cat-section {
    scroll-margin-top: 72px;
    padding-bottom: 16px;
  }

  .cat-section + .cat-section {
    margin-top: 12px;
    padding-top: 32px !important;
    border-top: 1px solid var(--color-pale-slate);
  }

  .cat-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px 24px;
    margin-bottom: 8px;
    max-width: 1100px;
  }

  .cat-header-copy {
    min-width: min(100%, 420px);
    flex: 1;
  }

  .cat-intro {
    margin: 0;
    max-width: 52ch;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-iron);
  }

  .cat-header-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .subhead {
    margin: 28px 0 12px;
    font-size: 13px;
    font-weight: 650;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-graphite);
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
    max-width: 1100px;
  }

  .guide-card {
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
    overflow: hidden;
    padding: 0;
  }

  .guide-card:hover {
    text-decoration: none;
    color: inherit;
    border-color: var(--color-dove-gray);
  }

  .guide-card-body {
    padding: 18px 20px 20px;
  }

  .guide-card p {
    margin: 0 0 12px;
    color: var(--color-iron);
    font-size: 14px;
    line-height: 1.5;
  }

  .linkish {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-cobalt);
  }

  @media (max-width: 640px) {
    .guide-grid {
      grid-template-columns: 1fr;
    }

    .cat-header-actions {
      width: 100%;
    }

    .cat-header-actions .btn {
      flex: 1;
      text-align: center;
      justify-content: center;
    }
  }
</style>
