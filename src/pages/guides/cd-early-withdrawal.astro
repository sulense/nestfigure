---
import GuideLayout from '../../layouts/GuideLayout.astro';
import { calculateCd } from '../../lib/cdMath';

const title = 'CD Early Withdrawal Penalties: What CFPB Says | Nestfigure';
const description =
  'Educational overview of CD early withdrawal: CFPB guidance that early withdrawal typically incurs a penalty, Truth in Savings disclosure context, FDIC/NCUA insurance notes, and what Nestfigure’s calculator omits.';

function money(n: number) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(n);
}

const heldToMaturity = calculateCd({
  principal: 10000,
  ratePercent: 4.5,
  rateIsApy: true,
  termMonths: 12,
  compounding: 'daily',
  monthlyDeposit: 0,
});

const CFPB_CD =
  'https://www.consumerfinance.gov/ask-cfpb/what-is-a-certificate-of-deposit-cd-en-917/';
const REG_DD = 'https://www.consumerfinance.gov/rules-policy/regulations/1030/';
const ECFR_DD = 'https://www.ecfr.gov/current/title-12/chapter-X/part-1030';
const FDIC =
  'https://www.fdic.gov/resources/deposit-insurance/understanding-deposit-insurance';
const EDIE = 'https://edie.fdic.gov/';
const NCUA = 'https://ncua.gov/consumers/share-insurance-coverage';

const faqs = [
  {
    question: 'What happens if I withdraw a CD early?',
    answer:
      'According to the CFPB’s Ask CFPB page “What is a certificate of deposit (CD)?”, withdrawing money early means paying a penalty fee to the bank. Exact fees are product-specific—read your agreement. Source: consumerfinance.gov Ask CFPB CD explainer.',
  },
  {
    question: 'What should I compare when shopping for a CD?',
    answer:
      'The CFPB advises comparing the term (how long you leave money in), the interest rate you earn, and the amount of the early-withdrawal penalty. Nestfigure does not list live bank rates.',
  },
  {
    question: 'Does Nestfigure subtract early withdrawal penalties?',
    answer:
      'No. Nestfigure’s CD calculator estimates interest under stated rate, term, and compounding assumptions only. It does not model penalties, fees, or promotional rates. See how Nestfigure’s CD calculator works.',
  },
  {
    question: 'Are CDs FDIC- or NCUA-insured?',
    answer:
      'The CFPB states that CDs offered by banks are insured up to $250,000 by the FDIC, and those offered by credit unions are insured up to $250,000 by the NCUA. Coverage depends on ownership categories—use FDIC EDIE or NCUA materials for your structure.',
  },
  {
    question: 'How should I compare CDs if I might need the money early?',
    answer:
      'The CFPB advises comparing term, interest rate, and the early-withdrawal penalty. Nestfigure’s CD vs savings guide covers liquidity tradeoffs with CFPB, FDIC, and NCUA citations.',
  },
];
---

