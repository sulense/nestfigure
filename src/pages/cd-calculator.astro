---
import BaseLayout from '../layouts/BaseLayout.astro';
import CdCalculator from '../components/CdCalculator.astro';
import ShareEmbedBar from '../components/ShareEmbedBar.astro';
import AuthorByline from '../components/AuthorByline.astro';
import FigureCdFlow from '../components/figures/FigureCdFlow.astro';
import FigureFormula from '../components/figures/FigureFormula.astro';
import FigureWorkedExample from '../components/figures/FigureWorkedExample.astro';
import FigureTermCompare from '../components/figures/FigureTermCompare.astro';
import FigureCdVsSavings from '../components/figures/FigureCdVsSavings.astro';
import { calculateCd } from '../lib/cdMath';

const title = 'CD Calculator — Free CD Interest & APY Estimator (2026)';
const description =
  'Free CD calculator. Estimate interest earned and maturity value by principal, APY, term, and compounding. Certificate of deposit calculator — no signup.';

function money(n: number) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(n);
}

const sample10k1y = calculateCd({
  principal: 10000,
  ratePercent: 4.5,
  rateIsApy: true,
  termMonths: 12,
  compounding: 'daily',
  monthlyDeposit: 0,
});

const calcFaqs = [
  {
    question: 'How does a CD calculator work?',
    answer:
      'A CD calculator estimates certificate of deposit maturity value from deposit amount, interest rate or APY, term length, and compounding frequency using standard compound-interest formulas. Nestfigure’s tool shows interest earned, final balance, a period schedule, a term comparison table, and optional PDF export. Results are educational estimates only—not bank quotes or personalized advice. Methodology: https://nestfigure.com/about/',
  },
  {
    question: 'How much will a $10,000 CD make in one year?',
    answer: `Direct answer: It depends on the APY on your disclosure—not a single fixed amount. Nestfigure does not list live bank rates. For education only, Nestfigure’s model at a sample 4.50% APY for 12 months (daily compounding, no add-on deposits) shows ${money(sample10k1y.totalInterest)} of interest (balance ${money(sample10k1y.finalBalance)}). Full scenario with other sample APYs: https://nestfigure.com/guides/cd-10000-one-year/`,
  },
  {
    question: 'What is the difference between APY and interest rate on a CD?',
    answer:
      'Under the Consumer Financial Protection Bureau’s Regulation DD (Truth in Savings, 12 CFR Part 1030), annual percentage yield (APY) reflects the total interest paid based on the interest rate and compounding frequency for a 365-day period. The interest rate is the annual rate that does not reflect compounding. When deposit advertisements state a rate of return, Regulation DD requires that rate to be stated as an APY. Official text: https://www.consumerfinance.gov/rules-policy/regulations/1030/',
  },
  {
    question: 'How is CD interest calculated in this tool?',
    answer:
      'For discrete compounding Nestfigure uses the standard form A = P(1 + r/n)^(n·t), where P is principal, r is the annual nominal rate used in the model, n is compounding periods per year, and t is time in years. Continuous compounding uses A = P·e^(r·t). If you enter APY, the tool converts APY to an equivalent nominal rate for the selected compounding so the model’s effective yield matches that APY input under Nestfigure’s documented assumptions. Real banks may use different day-count conventions.',
  },
  {
    question: 'How often do CDs compound?',
    answer:
      'Compounding frequency is set by each product’s terms—Nestfigure does not assert a single industry standard. This calculator lets you model daily, monthly, quarterly, semi-annual, annual, or continuous compounding for education. Always read the institution’s disclosure for the account you open.',
  },
  {
    question: 'Can I add money to a CD after opening it?',
    answer:
      'Account rules vary by product. Some CDs do not allow additional deposits during the term; some “add-on” products do. Nestfigure’s optional monthly deposit field is for planning models only and does not mean a given bank allows add-ons. Confirm with the institution.',
  },
  {
    question: 'What happens if I withdraw a CD early?',
    answer:
      'According to the CFPB’s Ask CFPB page “What is a certificate of deposit (CD)?” (https://www.consumerfinance.gov/ask-cfpb/what-is-a-certificate-of-deposit-cd-en-917/), withdrawing money early means paying a penalty fee to the bank. The CFPB advises comparing term, interest rate, and the amount of the early-withdrawal penalty when shopping. This calculator does not subtract penalties. Confirm exact fees in your agreement.',
  },
  {
    question: 'Are CDs FDIC- or NCUA-insured?',
    answer:
      'The same CFPB CD explainer states that CDs offered by banks are insured up to $250,000 by the FDIC, and those offered by credit unions are insured up to $250,000 by the NCUA. FDIC: https://www.fdic.gov/resources/deposit-insurance/understanding-deposit-insurance — NCUA: https://ncua.gov/consumers/share-insurance-coverage — Coverage depends on ownership categories; use FDIC’s EDIE (https://edie.fdic.gov/) or NCUA materials for your structure.',
  },
  {
    question: 'Is this CD calculator free?',
    answer:
      'Yes. Nestfigure’s CD calculator is free with no signup. Results are educational estimates, not offers from a bank and not personalized financial, tax, or investment advice.',
  },
  {
    question: 'How accurate is this certificate of deposit calculator?',
    answer:
      'Formulas are standard compound-interest identities documented at https://nestfigure.com/about/. Real accounts may differ because of day-count methods, fees, tiered rates, compounding rules, or promotions. Always verify with your financial institution’s disclosures.',
  },
  {
    question: 'Should I use a CD or a high-yield savings account?',
    answer:
      'Neither is always better for every person. The CFPB notes CDs involve a set term and that early withdrawal typically incurs a penalty, which can make them less suitable for money you may need suddenly. Liquid savings products trade different access and rate features. Compare APY, liquidity, and penalties for offers available to you. Nestfigure comparison guide: https://nestfigure.com/guides/cd-vs-savings/',
  },
  {
    question: 'How do I compare 6-month vs 12-month CD terms?',
    answer:
      'Enter your deposit and an APY from a real disclosure, then use Nestfigure’s term comparison table or term presets. Longer terms only help if the rate and your timeline justify locking funds. Early-withdrawal penalties (described generally by the CFPB for CDs) can reduce or erase gains if you exit early. Product-specific penalties always control.',
  },
  {
    question: 'Can I prefill the calculator from a link?',
    answer:
      'Yes. Supported query parameters: principal (or deposit), rate or apy, rateType (apy|apr), term, termUnit (months|years), months, years, compounding, monthlyDeposit. Example: https://nestfigure.com/cd-calculator/?principal=10000&rate=4.5&term=12&termUnit=months&compounding=daily',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'CD Calculator',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    description,
    url: 'https://nestfigure.com/cd-calculator/',
    author: {
      '@type': 'Person',
      name: 'John Rey Balais',
      url: 'https://nestfigure.com/about/',
      jobTitle: 'Developer',
    },
    provider: {
      '@type': 'Organization',
      name: 'Nestfigure',
      url: 'https://nestfigure.com/',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: calcFaqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/cd-calculator/"
  ogImage="/images/feature-cd-calculator.webp"
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Free CD calculator</p>
      <h1 class="display">
        CD Calculator<br />
        <span class="grad">Interest & maturity value</span>
      </h1>
      <p class="lead">
        Free certificate of deposit calculator. Estimate interest earned and final balance using deposit, APY or
        rate, term, and compounding — built for clear, no-signup planning.
      </p>
      <AuthorByline variant="compact" />
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <CdCalculator />
      <ShareEmbedBar
        path="/cd-calculator/"
        embedPath="/embed/cd-calculator/"
        title="Nestfigure CD Calculator — free CD interest & APY estimator"
      />
    </div>
  </section>

  <section class="section section-soft">
    <div class="container prose">
      <h2>How this CD calculator works</h2>
      <p>
        A <strong>CD calculator</strong> (certificate of deposit calculator) projects what your deposit could be
        worth at maturity. Enter your initial deposit, the APY or nominal rate, how long you’ll hold the CD, and how
        often interest compounds. The tool returns estimated interest earned, final balance, and a period-by-period
        schedule.
      </p>
      <p>
        Use it as a <strong>CD rate calculator</strong> or <strong>CD interest calculator</strong> when comparing
        terms (3-month, 6-month, 1-year, 5-year) or banks. Results are illustrative only — not a quote from any bank.
      </p>

      <FigureCdFlow />

      <h2>CD interest formula</h2>
      <p>For standard compounding, the calculator uses the formula below. If you enter <strong>APY</strong>, we convert it to the equivalent nominal rate for your chosen compounding so the effective yield matches.</p>
      <FigureFormula />

      <h2>Example</h2>
      <p>
        Deposit <strong>$10,000</strong> at <strong>4.50% APY</strong> for <strong>12 months</strong> with daily
        compounding. Interest earned is <strong>$450.00</strong> and the maturity balance is
        <strong>$10,450.00</strong>—the same defaults you can load in the tool above.
      </p>
      <FigureWorkedExample caption='Try these inputs in the calculator: $10,000 · 4.50% APY · 12 months · daily compounding.' />

      <h2>Comparing terms at the same rate</h2>
      <p>
        Longer terms earn more interest at the same APY because money compounds longer—but you lock funds for longer.
        The table uses the same deposit and APY as the example above.
      </p>
      <FigureTermCompare />

      <h2>Tips for comparing CDs</h2>
      <ul>
        <li>Compare <strong>APY</strong>, not just the headline rate, so compounding is apples-to-apples.</li>
        <li>Match the <strong>term</strong> to when you’ll need the money; early withdrawal penalties can erase gains.</li>
        <li>Confirm FDIC or NCUA insurance limits if safety is your priority.</li>
        <li>Use the on-page <strong>term comparison table</strong> in the calculator for your own rate and deposit.</li>
        <li>Read <a href="/guides/cd-vs-savings/">CD vs high-yield savings</a> before locking cash you might need early.</li>
      </ul>
      <FigureCdVsSavings />

      <h2>Worked scenarios</h2>
      <p>Step-by-step pages with sample-APY tables and prefilled calculator links:</p>
      <ul>
        <li>
          <a href="/guides/cd-10000-one-year/">How much will a $10,000 CD make in one year?</a>
        </li>
        <li>
          <a href="/guides/cd-10000-6-months/">How much will a $10,000 CD make in 6 months?</a>
        </li>
        <li>
          <a href="/guides/cd-20000-5-years/">What if I put $20,000 in a CD for 5 years?</a>
        </li>
        <li>
          <a href="/guides/cd-100000-6-months/">How much will $100,000 make in a 6 month CD?</a>
        </li>
      </ul>

      <h2>Learn more</h2>
      <ul>
        <li><a href="/guides/how-cd-interest-works/">How CD interest works</a> — APY, compounding, and formulas</li>
        <li><a href="/guides/cd-vs-savings/">CD vs savings</a> — liquidity vs locked rates</li>
        <li><a href="/faq/certificate-of-deposit/">CD FAQ</a> — rates, terms, safety, myths</li>
        <li><a href="/about/">Methodology</a> — exact assumptions we use</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow" style="text-align:center;">FAQ</p>
      <h2 class="heading" style="text-align:center; margin-bottom: 32px;">CD calculator questions</h2>
      <div class="faq" style="max-width: 720px; margin: 0 auto;">
        {
          calcFaqs.map((f, i) => (
            <details open={i === 0}>
              <summary>
                <h3>{f.question}</h3>
              </summary>
              <p>{f.answer}</p>
            </details>
          ))
        }
      </div>
      <p style="text-align:center; margin-top: 20px; font-size: 14px;">
        More questions:
        <a href="/faq/certificate-of-deposit/">Certificate of deposit FAQ</a>
      </p>

      <div style="max-width: 720px; margin: 28px auto 0;">
        <AuthorByline variant="card" />
      </div>

      <p class="disclaimer container" style="max-width: 720px; margin-left: auto; margin-right: auto;">
        <strong>Disclaimer:</strong> Nestfigure provides educational tools only. CD rates, APYs, compounding, and
        penalties vary by institution and product. This is not financial, tax, or investment advice. Last updated:
        July 2026.
      </p>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container" style="text-align:center;">
      <p class="eyebrow">Coming next</p>
      <h2 class="heading">More personal finance tools</h2>
      <p class="lead" style="margin: 0 auto 24px;">
        Paycheck, raise, overtime, and credit payoff calculators — same niche, tightly connected.
      </p>
      <a class="btn btn-secondary" href="/about/">About our methodology</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-inner .lead {
    margin-bottom: 0;
  }

  code {
    font-family: var(--font-mono);
  }

  .faq summary h3 {
    display: inline;
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    font-family: var(--font-ui);
    letter-spacing: -0.01em;
  }
</style>
