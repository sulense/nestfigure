---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About Nestfigure — Who Builds These Calculators';
const description =
  'Meet John Rey Balais, the developer behind Nestfigure. Who we are, how we publish free finance tools, and where to find our math and sources.';

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'John Rey Balais',
  jobTitle: 'Developer',
  description:
    'Developer building Nestfigure—free personal finance calculators and educational guides.',
  image: 'https://nestfigure.com/images/john-rey-balais.webp',
  url: 'https://nestfigure.com/about/',
  worksFor: {
    '@type': 'Organization',
    name: 'Nestfigure',
    url: 'https://nestfigure.com/',
  },
};

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Nestfigure',
  url: 'https://nestfigure.com/',
  description:
    'Free personal finance calculators and educational guides. Estimates for education only—not bank quotes or financial advice.',
  founder: {
    '@type': 'Person',
    name: 'John Rey Balais',
  },
  logo: 'https://nestfigure.com/logo-icon.svg',
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/about/"
  jsonLd={[personLd, orgLd]}
>
  <section class="hero">
    <div class="container" style="text-align:center;display:flex;flex-direction:column;align-items:center;">
      <p class="eyebrow">Trust &amp; authorship</p>
      <h1 class="display" style="font-size:clamp(36px,5vw,56px);">About Nestfigure</h1>
      <p class="lead">
        Who builds Nestfigure, how we publish, and where to find the math behind each calculator.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container prose">
      <h2>Who builds Nestfigure</h2>
      <div class="founder card">
        <picture>
          <source srcset="/images/john-rey-balais.webp" type="image/webp" />
          <img
            class="founder-photo"
            src="/images/john-rey-balais.jpg"
            alt="John Rey Balais, developer of Nestfigure"
            width="160"
            height="160"
            loading="eager"
            decoding="async"
          />
        </picture>
        <div class="founder-copy">
          <p class="founder-name">John Rey Balais</p>
          <p class="founder-role">Developer · Nestfigure</p>
          <p>
            I’m a developer building Nestfigure—free personal finance calculators and educational guides. I focus on
            clear math, transparent assumptions, official U.S. source citations where claims need them, and tools you
            can use without signing up.
          </p>
          <p>
            Nestfigure is not a bank, broker, employer, or adviser. Calculator results are educational estimates under
            documented formulas—not offers, rate quotes, payroll, or personalized advice. Report factual errors via the
            <a href="/contact/">contact form</a>.
          </p>
        </div>
      </div>

      <h2>What we build</h2>
      <p>
        Nestfigure stays in personal finance: free calculators, short guides, worked examples, and common questions.
        Live tools include the <a href="/cd-calculator/">CD calculator</a> and
        <a href="/raise-calculator/">raise calculator</a>. Each one lets you share results, copy numbers, download a PDF,
        or open a ready-made example. Future tools may include paycheck, overtime, and debt payoff—still free learning
        tools with the same clear layout.
      </p>
      <p>
        Browse <a href="/calculators/">all calculators</a> or <a href="/guides/">all guides</a> (grouped by calculator).
      </p>

      <h2>Who authors this content</h2>
      <p>
        Content is published by <strong>Nestfigure</strong> and written or reviewed by
        <strong>John Rey Balais</strong>. We do not invent guest “expert” personas or fabricated credentials. Deposit
        topics cite CFPB, FDIC, and NCUA materials; wage and price context cites BLS; federal withholding context cites
        IRS Publication 15-T. We do not invent live bank rates or personal “good raise” judgments.
      </p>

      <h2>Where to find how we calculate</h2>
      <p>
        <strong>This About page is about people and how we publish</strong>—not the full math for each tool. For
        formulas, assumptions, and what we leave out, open:
      </p>
      <ul>
        <li><a href="/methodology/">How we calculate</a></li>
        <li><a href="/methodology/cd-calculator/">CD calculator math</a></li>
        <li><a href="/methodology/raise-calculator/">Raise calculator math</a></li>
      </ul>

      <h2>Guides, examples &amp; questions</h2>
      <ul>
        <li><a href="/guides/">All guides &amp; examples</a></li>
        <li><a href="/faq/">Common questions</a></li>
        <li><a href="/faq/certificate-of-deposit/">CD questions</a></li>
        <li><a href="/faq/raise-calculator/">Raise questions</a></li>
      </ul>

      <h2>Calculators</h2>
      <ul>
        <li><a href="/cd-calculator/">CD calculator</a></li>
        <li><a href="/raise-calculator/">Raise calculator</a></li>
        <li><a href="/calculators/">All calculators</a></li>
      </ul>

      <h2>Primary external references we rely on</h2>
      <ul>
        <li>
          <a href="https://www.consumerfinance.gov/rules-policy/regulations/1030/" rel="noopener noreferrer" target="_blank"
            >CFPB — Regulation DD (Truth in Savings)</a
          >
        </li>
        <li>
          <a
            href="https://www.consumerfinance.gov/ask-cfpb/what-is-a-certificate-of-deposit-cd-en-917/"
            rel="noopener noreferrer"
            target="_blank">CFPB — What is a CD?</a
          >
        </li>
        <li>
          <a
            href="https://www.fdic.gov/resources/deposit-insurance/understanding-deposit-insurance"
            rel="noopener noreferrer"
            target="_blank">FDIC — Deposit insurance</a
          >
        </li>
        <li>
          <a href="https://ncua.gov/consumers/share-insurance-coverage" rel="noopener noreferrer" target="_blank"
            >NCUA — Share insurance coverage</a
          >
        </li>
        <li>
          <a href="https://www.bls.gov/eci/" rel="noopener noreferrer" target="_blank"
            >BLS — Employment Cost Index (wages &amp; salaries)</a
          >
        </li>
        <li>
          <a href="https://www.irs.gov/publications/p15t" rel="noopener noreferrer" target="_blank"
            >IRS — Publication 15-T (federal income tax withholding methods)</a
          >
        </li>
      </ul>

      <h2>Contact</h2>
      <p>
        Use the <a href="/contact/">contact form</a> for questions, corrections, or feedback about Nestfigure
        calculators and guides.
      </p>

      <p class="disclaimer">Last reviewed: July 22, 2026.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .founder {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 24px;
    align-items: start;
    padding: 20px;
    margin: 16px 0 28px;
  }

  .founder-photo {
    width: 160px;
    height: 160px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--color-pale-slate);
    background: #f0f5fe;
  }

  .founder-copy {
    min-width: 0;
  }

  .founder-name {
    margin: 0 0 4px;
    font-size: 20px;
    font-weight: 650;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .founder-role {
    margin: 0 0 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-graphite);
  }

  .founder-copy p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .founder {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }

    .founder-copy p {
      text-align: left;
    }
  }
</style>
